#!/bin/bash
# Run `gh skill install` against every harness listed in SKILL_HARNESSES (.env)
# for every source in registry.yaml. Forwarded to sync.sh, which handles
# the actual install and early-exits when SKILL_HARNESSES is empty.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if ! command -v gh &>/dev/null; then
  echo "  Skipping skill-sync (gh CLI not found)"
  exit 0
fi

if ! gh skill --help &>/dev/null; then
  echo "  Skipping skill-sync (gh skill subcommand unavailable — upgrade gh to v2.90+)"
  exit 0
fi

bash "$SCRIPT_DIR/sync.sh" --force
