#!/bin/bash
# Sync starship config to ~/.config/starship.toml

DEST="$HOME/.config/starship.toml"
SOURCE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ -L "$DEST" ]]; then
    rm "$DEST"
elif [[ -f "$DEST" ]]; then
    mv "$DEST" "$DEST.bak"
fi

ln -s "$SOURCE_DIR/starship.toml" "$DEST"
echo "  starship config synced"
