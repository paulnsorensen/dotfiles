{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_TOOL_SEARCH": "true",
    "SSL_CERT_FILE": "/etc/ssl/cert.pem"
  },
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(rtk:*)",
      "Bash(ls:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(test:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(touch:*)",
      "Bash(chmod:*)",
      "Bash(dirname:*)",
      "Bash(basename:*)",
      "Bash(realpath:*)",
      "Bash(bats:*)",
      "Bash(pytest:*)",
      "Bash(uv:*)",
      "Bash(npx:*)",
      "Bash(npm test:*)",
      "Bash(npm run:*)",
      "Bash(go test:*)",
      "Bash(cargo test:*)",
      "Bash(cargo check:*)",
      "Bash(cargo build:*)",
      "Bash(wt-git:*)",
      "Bash(ccw-sweep:*)",
      "Bash(dots:*)",
      "Bash(prek:*)",
      "Bash(fd:*)",
      "Bash(rg:*)",
      "Bash(sg:*)",
      "Bash(sd:*)",
      "Bash(gh:*)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(gh repo:*)",
      "Bash(gh run:*)",
      "Bash(gh api:*)",
      "Bash(yq:*)",
      "Bash(jq:*)",
      "Bash(procs:*)",
      "Bash(claude:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo fmt:*)",
      "Bash(cargo nextest:*)",
      "Bash(just:*)",
      "Bash(tokei:*)",
      "Bash(node:*)",
      "Bash(duckdb:*)",
      "Bash(python3:*)",
      "Edit",
      "Write",
      "mcp__plugin_playwright_playwright__*",
      "mcp__context7__*",
      "mcp__claude_ai_Context7__*",
      "mcp__claude_ai_Gmail__*",
      "mcp__claude_ai_Google_Calendar__*",
      "mcp__claude_ai_Excalidraw__*",
      "mcp__claude_ai_Mermaid_Chart__*",
      "mcp__plugin_github_github__*",
      "mcp__shadcn__*",
      "mcp__tavily__*",
      "mcp__serper__*",
      "mcp__code-review-graph__*",
      "mcp__tilth__*",
      "WebSearch",
      "WebFetch",
      "Skill"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/hook-runner.js\" write-guard.js",
            "statusMessage": "Checking write target..."
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/hook-runner.js\" phantom-file-check.js",
            "statusMessage": "Checking file..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/auto-format.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/session-start-cheese-flair.sh\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "bash-language-server@claude-code-lsps": true,
    "vtsls@claude-code-lsps": true,
    "yaml-language-server@claude-code-lsps": true,
    "rust-analyzer@claude-code-lsps": true,
    "pyright@claude-code-lsps": true,
    "gopls@claude-code-lsps": true,
    "claude-md-management@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "claude-hud@claude-hud": true
  },
  "extraKnownMarketplaces": {
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    },
    "claude-code-lsps": {
      "source": {
        "source": "github",
        "repo": "boostvolt/claude-code-lsps"
      }
    }
  },
  "sandbox": {
    "network": {
      "allowedDomains": [
        "127.0.0.1",
        "localhost",
        "github.com",
        "api.github.com",
        "raw.githubusercontent.com",
        "objects.githubusercontent.com",
        "api.anthropic.com",
        "docs.anthropic.com",
        "mcp-proxy.anthropic.com",
        "registry.npmjs.org",
        "context7.com",
        "mcp.context7.com",
        "ui.shadcn.com",
        "pypi.org",
        "files.pythonhosted.org",
        "crates.io",
        "static.crates.io",
        "api.githubcopilot.com",
        "api.tavily.com",
        "mcp.tavily.com",
        "google.serper.dev"
      ],
      "allowLocalBinding": true
    },
    "filesystem": {
      "allowWrite": [
        "~/Dev/.prek"
      ]
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-daltonized",
  "editorMode": "vim",
  "skipAutoPermissionPrompt": true
}
