{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_TOOL_SEARCH": "true",
    "SSL_CERT_FILE": "/etc/ssl/cert.pem"
  },
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(test:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(touch:*)",
      "Bash(chmod:*)",
      "Bash(dirname:*)",
      "Bash(basename:*)",
      "Bash(realpath:*)",
      "Bash(bats:*)",
      "Bash(pytest:*)",
      "Bash(uv:*)",
      "Bash(npx:*)",
      "Bash(npm test:*)",
      "Bash(npm run:*)",
      "Bash(go test:*)",
      "Bash(cargo test:*)",
      "Bash(cargo check:*)",
      "Bash(cargo build:*)",
      "Bash(wt-git:*)",
      "Bash(ccw-sweep:*)",
      "Bash(dots:*)",
      "Bash(prek:*)",
      "Bash(fd:*)",
      "Bash(rg:*)",
      "Bash(sg:*)",
      "Bash(sd:*)",
      "Bash(gh:*)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(gh repo:*)",
      "Bash(gh run:*)",
      "Bash(gh api:*)",
      "Bash(yq:*)",
      "Bash(jq:*)",
      "Bash(procs:*)",
      "Bash(do:*)",
      "Bash(claude:*)",
      "Edit",
      "Write",
      "mcp__serena__*",
      "mcp__plugin_playwright_playwright__*",
      "mcp__context7__*",
      "mcp__claude_ai_Context7__*",
      "mcp__claude_ai_Gmail__*",
      "mcp__claude_ai_Google_Calendar__*",
      "mcp__claude_ai_Excalidraw__*",
      "mcp__claude_ai_Mermaid_Chart__*",
      "mcp__octocode__*",
      "mcp__plugin_github_github__*",
      "mcp__shadcn__*",
      "WebSearch",
      "WebFetch"
    ]
  },
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"$HOME/.claude/hooks/pre-compact.sh\"",
            "statusMessage": "Saving session context...",
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"$HOME/.claude/hooks/post-fresh-start.sh\"",
            "statusMessage": "Priming session context..."
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"$HOME/.claude/hooks/post-compact.sh\"",
            "statusMessage": "Restoring session context..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/semantic-stop-guard.js\"",
            "statusMessage": "Evaluating response quality..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"$HOME/.claude/hooks/on-session-end.sh\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/bin/bash -c 'PLUGIN_DIR=$(ls -td ~/.claude/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | head -1); INDEX_JS=\"${PLUGIN_DIR}dist/index.js\"; if [ -z \"$PLUGIN_DIR\" ] || [ ! -f \"$INDEX_JS\" ]; then exit 0; fi; NODE=$(command -v node) || exit 0; \"$NODE\" \"$INDEX_JS\"'"
  },
  "enabledPlugins": {
    "bash-language-server@claude-code-lsps": true,
    "vtsls@claude-code-lsps": true,
    "yaml-language-server@claude-code-lsps": true,
    "rust-analyzer@claude-code-lsps": true,
    "pyright@claude-code-lsps": true,
    "gopls@claude-code-lsps": true,
    "solargraph@claude-code-lsps": true,
    "hookify@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "claude-hud@claude-hud": true
  },
  "extraKnownMarketplaces": {
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    },
    "claude-code-lsps": {
      "source": {
        "source": "github",
        "repo": "boostvolt/claude-code-lsps"
      }
    }
  },
  "sandbox": {
    "network": {
      "allowedDomains": [
        "127.0.0.1",
        "localhost",
        "github.com",
        "api.github.com",
        "raw.githubusercontent.com",
        "objects.githubusercontent.com",
        "api.anthropic.com",
        "docs.anthropic.com",
        "mcp-proxy.anthropic.com",
        "registry.npmjs.org",
        "context7.com",
        "mcp.context7.com",
        "ui.shadcn.com",
        "octocode-mcp-host.onrender.com",
        "pypi.org",
        "files.pythonhosted.org",
        "crates.io",
        "static.crates.io",
        "api.githubcopilot.com"
      ],
      "allowLocalBinding": true
    },
    "filesystem": {}
  },
  "skipDangerousModePermissionPrompt": true
}
