{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_TOOL_SEARCH": "true",
    "SSL_CERT_FILE": "/etc/ssl/cert.pem"
  },
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(test:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(touch:*)",
      "Bash(chmod:*)",
      "Bash(dirname:*)",
      "Bash(basename:*)",
      "Bash(realpath:*)",
      "Bash(bats:*)",
      "Bash(pytest:*)",
      "Bash(uv:*)",
      "Bash(npx:*)",
      "Bash(npm test:*)",
      "Bash(npm run:*)",
      "Bash(go test:*)",
      "Bash(cargo test:*)",
      "Bash(cargo check:*)",
      "Bash(cargo build:*)",
      "Bash(wt-git:*)",
      "Bash(ccw-sweep:*)",
      "Bash(dots:*)",
      "Bash(prek:*)",
      "Bash(fd:*)",
      "Bash(rg:*)",
      "Bash(sg:*)",
      "Bash(sd:*)",
      "Bash(gh:*)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(gh repo:*)",
      "Bash(gh run:*)",
      "Bash(gh api:*)",
      "Bash(yq:*)",
      "Bash(jq:*)",
      "Bash(procs:*)",
      "Bash(do:*)",
      "Bash(claude:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo fmt:*)",
      "Bash(cargo nextest:*)",
      "Bash(just:*)",
      "Bash(tokei:*)",
      "Bash(node:*)",
      "Bash(duckdb:*)",
      "Bash(python3:*)",
      "Edit",
      "Write",
      "mcp__plugin_playwright_playwright__*",
      "mcp__context7__*",
      "mcp__claude_ai_Context7__*",
      "mcp__claude_ai_Gmail__*",
      "mcp__claude_ai_Google_Calendar__*",
      "mcp__claude_ai_Excalidraw__*",
      "mcp__claude_ai_Mermaid_Chart__*",
      "mcp__octocode__*",
      "mcp__plugin_github_github__*",
      "mcp__shadcn__*",
      "mcp__tavily__*",
      "mcp__serper__*",
      "mcp__code-review-graph__*",
      "WebSearch",
      "WebFetch",
      "Skill"
    ]
  },
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"$HOME/.claude/hooks/pre-compact.sh\"",
            "statusMessage": "Saving session context...",
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"$HOME/.claude/hooks/post-fresh-start.sh\"",
            "statusMessage": "Priming session context..."
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"$HOME/.claude/hooks/post-compact.sh\"",
            "statusMessage": "Restoring session context..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "agent",
            "prompt": "Check if the assistant's last message is asking the user for permission to commit, push, or create a PR.\n\nHook context: $ARGUMENTS\n\nLook at last_assistant_message for patterns like:\n- \"Should I commit?\", \"Want me to commit?\", \"Ready to commit?\"\n- \"Should I push?\", \"Want me to push?\", \"Ready to push?\"\n- \"Should I create a PR?\", \"Want me to create a pull request?\"\n- \"Let me know when you're ready to...\"\n- \"Would you like me to commit/push/create a PR?\"\n- Ending with a question about committing, pushing, or PR creation\n\nIf the message is asking permission to commit, push, or create a PR, respond:\nWARN — Don't ask. Commit your changes, push, and open a PR.\n\nOtherwise respond: ALLOW\n\nOnly match clear commit/push/PR permission-asking. Do not match general questions about the code or approach.",
            "timeout": 60,
            "model": "haiku",
            "statusMessage": "Checking for commit hesitation..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"$HOME/.claude/hooks/on-session-end.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/hook-runner.js\" bash-guard.js",
            "statusMessage": "Checking command..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/hook-runner.js\" write-guard.js",
            "statusMessage": "Checking write target..."
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/hook-runner.js\" phantom-file-check.js",
            "statusMessage": "Checking file..."
          }
        ]
      },
      {
        "matcher": "mcp__plugin_github_github__add_reply_to_pull_request_comment",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/review-reply-guard.js\"",
            "statusMessage": "Checking reply for deferral..."
          }
        ]
      },
      {
        "matcher": "mcp__plugin_github_github__add_issue_comment",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/review-reply-guard.js\"",
            "statusMessage": "Checking reply for deferral..."
          }
        ]
      },
      {
        "matcher": "mcp__plugin_github_github__pull_request_review_write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/review-reply-guard.js\"",
            "statusMessage": "Checking reply for deferral..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/auto-format.js\"",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "bash-language-server@claude-code-lsps": true,
    "vtsls@claude-code-lsps": true,
    "yaml-language-server@claude-code-lsps": true,
    "rust-analyzer@claude-code-lsps": true,
    "pyright@claude-code-lsps": true,
    "gopls@claude-code-lsps": true,
    "claude-md-management@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "claude-hud@claude-hud": true,
    "cheese-flow@cheese-flow": true,
    "vaudeville@local": true
  },
  "extraKnownMarketplaces": {
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    },
    "claude-code-lsps": {
      "source": {
        "source": "github",
        "repo": "boostvolt/claude-code-lsps"
      }
    },
    "cheese-flow": {
      "source": {
        "source": "directory",
        "path": "/Users/paul/Dev/dotfiles/claude/plugins/local/cheese-flow"
      }
    },
    "todoist-flow": {
      "source": {
        "source": "directory",
        "path": "/Users/paul/Dev/dotfiles/claude/plugins/local/todoist-flow"
      }
    }
  },
  "sandbox": {
    "network": {
      "allowedDomains": [
        "127.0.0.1",
        "localhost",
        "github.com",
        "api.github.com",
        "raw.githubusercontent.com",
        "objects.githubusercontent.com",
        "api.anthropic.com",
        "docs.anthropic.com",
        "mcp-proxy.anthropic.com",
        "registry.npmjs.org",
        "context7.com",
        "mcp.context7.com",
        "ui.shadcn.com",
        "octocode-mcp-host.onrender.com",
        "pypi.org",
        "files.pythonhosted.org",
        "crates.io",
        "static.crates.io",
        "api.githubcopilot.com",
        "api.tavily.com",
        "mcp.tavily.com",
        "google.serper.dev"
      ],
      "allowLocalBinding": true
    },
    "filesystem": {
      "allowWrite": [
        "~/Dev/.prek"
      ]
    }
  },
  "skipDangerousModePermissionPrompt": true
}
