{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "permissions": {
    "allow": [
      "Bash(git fetch:*)",
      "Bash(git rebase:*)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git worktree:*)",
      "Bash(git rev-parse:*)",
      "Bash(git remote:*)",
      "Bash(git show:*)",
      "Bash(git blame:*)",
      "Bash(git stash list:*)",
      "Bash(ls:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(test:*)",
      "Bash(bats:*)",
      "Bash(pytest:*)",
      "Bash(npx jest:*)",
      "Bash(npx vitest:*)",
      "Bash(go test:*)",
      "Bash(cargo test:*)",
      "Bash(ccw-sweep:*)",
      "Bash(fd:*)",
      "Bash(rg:*)",
      "Bash(sg:*)",
      "Bash(gh:*)",
      "Bash(yq:*)",
      "Bash(jq:*)",
      "mcp__serena__*",
      "mcp__plugin_playwright_playwright__*",
      "mcp__context7__*",
      "mcp__octocode__*",
      "mcp__plugin_github_github__*",
      "WebSearch",
      "WebFetch"
    ]
  },
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/pre-compact.sh\"",
            "statusMessage": "Saving session context...",
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/post-fresh-start.sh\"",
            "statusMessage": "Priming session context..."
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/post-compact.sh\"",
            "statusMessage": "Restoring session context..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/on-session-end.sh\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c '\"/opt/homebrew/bin/node\" \"$(ls -td ~/.claude/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | head -1)dist/index.js\"'"
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "claude-hud@claude-hud": true
  },
  "extraKnownMarketplaces": {
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    }
  },
  "sandbox": {
    "network": {
      "allowedDomains": [
        "127.0.0.1",
        "localhost",
        "github.com",
        "api.github.com",
        "raw.githubusercontent.com",
        "api.anthropic.com",
        "docs.anthropic.com",
        "mcp-proxy.anthropic.com",
        "registry.npmjs.org",
        "context7.com",
        "mcp.context7.com",
        "ui.shadcn.com",
        "octocode-mcp-host.onrender.com",
        "pypi.org",
        "api.githubcopilot.com"
      ],
      "allowLocalBinding": true
    },
    "filesystem": {}
  },
  "skipDangerousModePermissionPrompt": true,
  "model": "opus"
}
