{
  "permissions": {
    "allow": [
      "Bash(git fetch:*)",
      "Bash(git rebase:*)",
      "Bash(gh *)",
      "mcp__octocode__*",
      "mcp__serena__*",
      "mcp__plugin_github_github__*",
      "mcp__plugin_context7_context7__*",
      "mcp__plugin_context7-plugin_context7__*",
      "mcp__plugin_playwright_playwright__*",
      "WebSearch",
      "WebFetch"
    ]
  },
  "model": "sonnet",
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/pre-compact.sh\"",
            "statusMessage": "Saving session context...",
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/post-fresh-start.sh\"",
            "statusMessage": "Priming session context..."
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/post-compact.sh\"",
            "statusMessage": "Re-priming MCP tools..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/on-session-end.sh\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": false,
    "bash-language-server@claude-code-lsps": true,
    "claude-md-management@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": false,
    "hookify@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "yaml-language-server@claude-code-lsps": true,
    "context7@claude-plugins-official": true,
    "context7-plugin@context7-marketplace": true,
    "solargraph@claude-code-lsps": true,
    "pyright@claude-code-lsps": true,
    "gopls@claude-code-lsps": true,
    "skill-creator@claude-plugins-official": true
  }
}
