{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_TOOL_SEARCH": "true",
    "SSL_CERT_FILE": "/etc/ssl/cert.pem"
  },
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(test:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(touch:*)",
      "Bash(chmod:*)",
      "Bash(dirname:*)",
      "Bash(basename:*)",
      "Bash(realpath:*)",
      "Bash(bats:*)",
      "Bash(pytest:*)",
      "Bash(uv:*)",
      "Bash(npx:*)",
      "Bash(npm test:*)",
      "Bash(npm run:*)",
      "Bash(go test:*)",
      "Bash(cargo test:*)",
      "Bash(cargo check:*)",
      "Bash(cargo build:*)",
      "Bash(wt-git:*)",
      "Bash(ccw-sweep:*)",
      "Bash(dots:*)",
      "Bash(prek:*)",
      "Bash(fd:*)",
      "Bash(rg:*)",
      "Bash(sg:*)",
      "Bash(sd:*)",
      "Bash(gh:*)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(gh repo:*)",
      "Bash(gh run:*)",
      "Bash(gh api:*)",
      "Bash(yq:*)",
      "Bash(jq:*)",
      "Bash(procs:*)",
      "Bash(do:*)",
      "Bash(claude:*)",
      "Edit",
      "Write",
      "mcp__plugin_playwright_playwright__*",
      "mcp__context7__*",
      "mcp__claude_ai_Context7__*",
      "mcp__claude_ai_Gmail__*",
      "mcp__claude_ai_Google_Calendar__*",
      "mcp__claude_ai_Excalidraw__*",
      "mcp__claude_ai_Mermaid_Chart__*",
      "mcp__octocode__*",
      "mcp__plugin_github_github__*",
      "mcp__shadcn__*",
      "mcp__tavily__*",
      "mcp__serper__*",
      "WebSearch",
      "WebFetch"
    ]
  },
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"$HOME/.claude/hooks/pre-compact.sh\"",
            "statusMessage": "Saving session context...",
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"$HOME/.claude/hooks/post-fresh-start.sh\"",
            "statusMessage": "Priming session context..."
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"$HOME/.claude/hooks/post-compact.sh\"",
            "statusMessage": "Restoring session context..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/paul/.claude/hooks/gsd-check-update.js\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "agent",
            "prompt": "You are the Self-Eval Sentinel. Audit the assistant's last message for quality violations.\n\nHook context: $ARGUMENTS\n\nEvaluate last_assistant_message against this checklist (PASS or FAIL each):\n\n1. Premature completion — TODO/FIXME/placeholder language, \"add later\", \"you can finish\", suggesting the user complete steps\n2. Scope reduction — Requirements silently dropped (\"for now\", \"as a starting point\", \"we can add X later\")\n3. False confidence — Claiming code works without test/build evidence shown in the message\n4. AI slop — Phrases like \"I've implemented\", \"This ensures\", \"This provides\", unnecessary summarization of what was just done\n5. Sycophancy — \"Great question!\", unearned praise, hollow agreement\n6. Hedging — \"should work\", \"might want to\", \"consider perhaps\" without verification\n7. Dismissing failures — Errors called \"pre-existing\" or \"unrelated\" without citing evidence (commit SHA, run ID, base branch check)\n8. Weak assertions — If test code is shown, assertions check existence/truthiness instead of exact values\n\nIf ALL applicable items PASS, respond: ALLOW\nIf ANY item FAILS, respond: BLOCK — then list each failure with item number and the offending text.\n\nRules:\n- Skip items that don't apply\n- Be strict on real violations, not style preferences\n- If stop_hook_active is true, check whether previously flagged violations were fixed — if yes, ALLOW",
            "model": "haiku",
            "timeout": 120,
            "statusMessage": "Self-eval sentinel auditing response..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "/bin/bash \"$HOME/.claude/hooks/on-session-end.sh\""
        }
      ]
    }
  ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/bash-guard.js\"",
            "statusMessage": "Checking command..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/write-guard.js\"",
            "statusMessage": "Checking write target..."
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/phantom-file-check.js\"",
            "statusMessage": "Checking file..."
          }
        ]
      },
      {
        "matcher": "mcp__plugin_github_github__add_reply_to_pull_request_comment",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/review-reply-guard.js\"",
            "statusMessage": "Checking reply for deferral..."
          }
        ]
      },
      {
        "matcher": "mcp__plugin_github_github__add_issue_comment",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/review-reply-guard.js\"",
            "statusMessage": "Checking reply for deferral..."
          }
        ]
      },
      {
        "matcher": "mcp__plugin_github_github__pull_request_review_write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/review-reply-guard.js\"",
            "statusMessage": "Checking reply for deferral..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/paul/.claude/hooks/gsd-prompt-guard.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/paul/.claude/hooks/gsd-context-monitor.js\"",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node \"/Users/paul/.claude/hooks/gsd-statusline.js\""
  },
  "enabledPlugins": {
    "bash-language-server@claude-code-lsps": true,
    "vtsls@claude-code-lsps": true,
    "yaml-language-server@claude-code-lsps": true,
    "rust-analyzer@claude-code-lsps": true,
    "pyright@claude-code-lsps": true,
    "gopls@claude-code-lsps": true,
    "solargraph@claude-code-lsps": true,
    "claude-md-management@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "claude-hud@claude-hud": true
  },
  "extraKnownMarketplaces": {
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    },
    "claude-code-lsps": {
      "source": {
        "source": "github",
        "repo": "boostvolt/claude-code-lsps"
      }
    }
  },
  "sandbox": {
    "network": {
      "allowedDomains": [
        "127.0.0.1",
        "localhost",
        "github.com",
        "api.github.com",
        "raw.githubusercontent.com",
        "objects.githubusercontent.com",
        "api.anthropic.com",
        "docs.anthropic.com",
        "mcp-proxy.anthropic.com",
        "registry.npmjs.org",
        "context7.com",
        "mcp.context7.com",
        "ui.shadcn.com",
        "octocode-mcp-host.onrender.com",
        "pypi.org",
        "files.pythonhosted.org",
        "crates.io",
        "static.crates.io",
        "api.githubcopilot.com",
        "api.tavily.com",
        "mcp.tavily.com",
        "google.serper.dev"
      ],
      "allowLocalBinding": true
    },
    "filesystem": {}
  },
  "skipDangerousModePermissionPrompt": true
}
