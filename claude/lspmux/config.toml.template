# lspmux server configuration
# Installed to: ~/.config/lspmux/config.toml

# How long (seconds) an idle language server instance is kept alive before
# being shut down. Frees memory when you're not actively working.
instance_timeout = 300

# How often (seconds) the garbage collector runs to reap idle instances.
gc_interval = 10

# Address the server listens on for incoming LSP client connections.
# Format: ["host", port]
listen = ["127.0.0.1", 27631]

# Address clients connect to when proxying to the lspmux server.
# Must match `listen` unless you're running server and clients on separate
# machines (unusual for a local setup).
connect = ["127.0.0.1", 27631]

# Log verbosity. Options: "error", "warn", "info", "debug", "trace"
log_filters = "info"

# Environment variables forwarded from the client to each spawned language
# server process. The "*" wildcard passes everything; entries prefixed with
# "!" exclude that variable. DESKTOP_STARTUP_ID and WINDOWID are X11
# artifacts that can confuse non-X11 language servers on macOS.
pass_environment = ["*", "!DESKTOP_STARTUP_ID", "!WINDOWID"]
