{
  "env": {
    "ENABLE_TOOL_SEARCH": "true"
  },
  "permissions": {
    "allow": [
      "Skill",
      "Agent",
      "Read",
      "Write",
      "Edit",
      "Grep",
      "Glob",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)",
      "Bash(gh api:*)",
      "Bash(gh search:*)",
      "Bash(gh-pr-batch:*)",
      "Bash(gh-pr-checks-batch:*)",
      "Bash(gh-pr-review:*)",
      "Bash(gh-issue-context:*)",
      "Bash(jq:*)",
      "Bash(yq:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(dirname:*)",
      "Bash(basename:*)",
      "Bash(realpath:*)",
      "TaskCreate",
      "TaskUpdate",
      "TaskList",
      "AskUserQuestion",
      "mcp__todoist__*",
      "mcp__context7__*",
      "mcp__tavily__*",
      "mcp__serper__*",
      "mcp__claude_ai_Gmail__*"
    ],
    "deny": [
      "NotebookEdit",
      "WebFetch",
      "WebSearch"
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "enabledPlugins": {
    "todoist-flow@todoist-flow": true
  }
}
