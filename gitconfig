[user]
	name = Paul Sorensen
	email = paulnsorensen@gmail.com

[branch]
  autosetuprebase = always

[fetch]
	prune = true

[push]
  default = simple

[commit]
	verbose = true

[color]
  ui = true
[color "diff"]
	meta = 241      # dim (#636363)
	func = 140      # magenta (#b287cd)
	old = 167       # red (#e8575b)
	new = 108       # green (#88b994)
	frag = 140      # magenta (#b287cd)
[color "status"]
	added = 108     # green (#88b994)
	untracked = 167 # red (#e8575b)
	nobranch = bold 167
	changed = 214   # yellow (#ffae00)
[color "interactive"]
	prompt = 103    # blue (#768da1)

[alias]
	cwork = !git config user.email paul.sorensen@uber.com
	cpersonal = !git config user.email paulnsorensen@gmail.com

[difftool "kdiff3"]
    trustExitCode = false
[difftool]
    prompt = false
[diff]
    tool = kdiff3
[mergetool "kdiff3"]
    trustExitCode = false
[mergetool]
    keepBackup = false
[merge]
    tool = kdiff3

[url "ssh://code.uber.internal/"]
	insteadOf = https://code.uber.internal/
[url "ssh://config.uber.internal/"]
	insteadOf = https://config.uber.internal/
[http "https://gopkg.uberinternal.com"]
	followRedirects = true
[http "https://gopkg.in"]
	followRedirects = true
[rerere]
	enabled = true
[include]
  path = .gitconfig.local
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[color "branch"]
	current = 45    # cyan (#00c4fb)
	local = 103     # blue (#768da1)
	remote = 108    # green (#88b994)
[init]
	defaultBranch = main

[pager]
	diff = delta
	log = delta
	blame = delta
	show = delta

[interactive]
	diffFilter = delta --color-only --features=interactive

[delta]
	navigate = true
	line-numbers = true
	light = false
	features = chocolate-donut

[delta "chocolate-donut"]
	# Diff backgrounds: theme bg #2a1c12 blended with red/green
	minus-style = syntax "#3d2219"
	minus-emph-style = syntax "#5a2b24"
	plus-style = syntax "#2d3520"
	plus-emph-style = syntax "#364428"
	# Line numbers
	line-numbers-minus-style = "#e8575b"
	line-numbers-plus-style = "#88b994"
	line-numbers-zero-style = "#636363"
	# Decorations
	commit-decoration-style = "#ffae00" box ul
	file-style = "#ffae00" ul
	file-decoration-style = none
	hunk-header-decoration-style = "#768da1" box
	hunk-header-style = file line-number "#768da1"
	hunk-header-file-style = "#ffae00"
	hunk-header-line-number-style = "#768da1"
