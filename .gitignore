# Folder view configuration files
/**/.DS_Store
/**/Desktop.ini

# Thumbnail cache files
._*
Thumbs.db

# Files that might appear on external disks
.Spotlight-V100
.Trashes

# iterm2 (live plist is generated from base + dynamic patches)
iterm2/background/i_know_how_to_make_ducks.png
iterm2/com.googlecode.iterm2.plist

# Environment files
.env
.env.local
/reference/
!claude/reference/

# Local-only authored artifacts (not yet promoted to tracked source).
# .ignore = ripgrep/hallouminate ignore-crate file (re-includes .cheese/
# scratch for local semantic indexing); ROADMAP.md = strategic direction doc.
.ignore
/ROADMAP.md


# Hook dependencies (installed by claude/.sync)
claude/hooks/node_modules/
claude/hooks/package-lock.json

# Cheese-flair assets — canonical copy lives under agents/. The base
# plugin tree at ~/.claude/plugins/local/global/{hooks,lib,reference}/
# is where ap deploys them (NOT through claude/.sync's directory
# symlinks anymore — settings.json's legacy hook entry was retired in
# favor of the plugin's own plugin.json wiring). The claude/lib/ +
# claude/reference/ paths remain ignored here only to keep stragglers
# from older deploys out of git on hosts that haven't fully migrated.
# Safe to drop these lines once every host is past the migration.
claude/lib/cheese-flair.sh
claude/reference/cheese-flair.md

# Harness-managed agent skill cache (written by `gh skill install`)
.agents/

# Serena's project-local data (memories, caches) — written when Serena's MCP
# server runs against this directory. Our config + global state live under
# ~/.serena/; this dir is per-project runtime state, not source.
.serena/

# Claude Code local state (settings.local.json, specs)
.claude/

# Hallouminate per-repo state. Track config.toml (portable, relative paths)
# and the curated wiki/ corpus so the repo:dotfiles:wiki setup travels with a
# clone; ignore everything else here (LanceDB caches, scratch indexes).
.hallouminate/*
!.hallouminate/config.toml
!.hallouminate/wiki/

# Cursor IDE runtime / install-cursor-plugin output that lands here when
# someone opens the repo's `cursor/` subdir as a workspace (Cursor treats
# it as `~/.cursor/`) or sets CURSOR_HOME wrong. The only intentional tree
# under cursor/ is plugins/ (the source for cheese-grok et al).
/cursor/*
!/cursor/plugins/
!/cursor/plugins/**

# Claude test sandbox (temporary test files from /test-sandbox skill)
.claude/testing/

# Vim auto-generated files
vim/.netrwhist
vim/undo/

# Git worktrees (Claude Code task isolation)
.worktrees/
.conductor/

# Workspace-local notebooks and context
.context/

# Cheese-flow research scratch (briesearch, /research outputs)
.cheese/

# VHS recording output
vhs/output/

# Backup files
*.bak

# Python cache
__pycache__/

# DuckDB databases
*.duckdb

# Ralph TUI
.ralph-tui/
skills/ralph-tui-*

# tmux (plugins managed by TPM, theme rebuilt on dots sync)
tmux/plugins/
tmux/theme.conf
