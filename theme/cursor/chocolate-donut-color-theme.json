  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#636363",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": {
        "foreground": "#88b994"
      }
    },
    {
      "name": "String interpolation",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.section.embedded",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#00c4fb"
      }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#e9b76b"
      }
    },
    {
      "name": "Constants",
      "scope": ["constant", "constant.language", "constant.character"],
      "settings": {
        "foreground": "#e9b76b"
      }
    },
    {
      "name": "Built-in constants",
      "scope": ["constant.language.boolean", "constant.language.null", "constant.language.undefined"],
      "settings": {
        "foreground": "#b287cd"
      }
    },
    {
      "name": "Keywords",
      "scope": ["keyword", "keyword.control", "keyword.operator.expression"],
      "settings": {
        "foreground": "#b287cd"
      }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator", "keyword.operator.assignment"],
      "settings": {
        "foreground": "#dac2b1"
      }
    },
    {
      "name": "Comparison and logical operators",
      "scope": [
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.relational",
        "keyword.operator.ternary"
      ],
      "settings": {
        "foreground": "#00c4fb"
      }
    },
    {
      "name": "Spread/rest operator",
      "scope": ["keyword.operator.spread", "keyword.operator.rest"],
      "settings": {
        "foreground": "#e8575b"
      }
    },
    {
      "name": "Storage types",
      "scope": ["storage", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#b287cd"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function"
      ],
      "settings": {
        "foreground": "#768da1"
      }
    },
    {
      "name": "Function parameters",
      "scope": ["variable.parameter", "meta.parameter"],
      "settings": {
        "foreground": "#ff7558"
      }
    },
    {
      "name": "Classes and types",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#ffae00"
      }
    },
    {
      "name": "Interfaces",
      "scope": ["entity.name.type.interface"],
      "settings": {
        "foreground": "#ffae00",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Enums",
      "scope": ["entity.name.type.enum"],
      "settings": {
        "foreground": "#ffae00"
      }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#dac2b1"
      }
    },
    {
      "name": "Variable - property",
      "scope": ["variable.other.property", "variable.other.object.property"],
      "settings": {
        "foreground": "#dac2b1"
      }
    },
    {
      "name": "Variable - constant",
      "scope": ["variable.other.constant"],
      "settings": {
        "foreground": "#e9b76b"
      }
    },
    {
      "name": "Language variable (this, self)",
      "scope": ["variable.language"],
      "settings": {
        "foreground": "#e8575b",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Tags (HTML/JSX)",
      "scope": ["entity.name.tag", "support.class.component"],
      "settings": {
        "foreground": "#e8575b"
      }
    },
    {
      "name": "Tag attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#ffae00",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Decorators / Annotations",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#e9b76b"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.definition.block",
        "punctuation.definition.parameters",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#9e9387"
      }
    },
    {
      "name": "Import/Export",
      "scope": ["keyword.control.import", "keyword.control.export", "keyword.control.from"],
      "settings": {
        "foreground": "#b287cd"
      }
    },
    {
      "name": "Regex",
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#00c4fb"
      }
    },
    {
      "name": "Escape characters",
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#00c4fb"
      }
    },
    {
      "name": "Markdown headings",
      "scope": ["markup.heading", "entity.name.section"],
      "settings": {
        "foreground": "#e8575b",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#ffae00",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#e9b76b",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown code",
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#88b994"
      }
    },
    {
      "name": "Markdown link",
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#349ee9"
      }
    },
    {
      "name": "Markdown list",
      "scope": ["markup.list", "punctuation.definition.list"],
      "settings": {
        "foreground": "#e8575b"
      }
    },
    {
      "name": "Diff inserted",
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#88b994"
      }
    },
    {
      "name": "Diff deleted",
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#e8575b"
      }
    },
    {
      "name": "Diff changed",
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#349ee9"
      }
    },
    {
      "name": "CSS properties",
      "scope": ["support.type.property-name.css"],
      "settings": {
        "foreground": "#768da1"
      }
    },
    {
      "name": "CSS values",
      "scope": ["support.constant.property-value.css"],
      "settings": {
        "foreground": "#e9b76b"
      }
    },
    {
      "name": "CSS units",
      "scope": ["keyword.other.unit.css"],
      "settings": {
        "foreground": "#e9b76b"
      }
    },
    {
      "name": "CSS selectors",
      "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": {
        "foreground": "#ffae00"
      }
    },
    {
      "name": "JSON keys",
      "scope": ["support.type.property-name.json"],
      "settings": {
        "foreground": "#768da1"
      }
    },
    {
      "name": "JSON string values",
      "scope": ["string.quoted.double.json"],
      "settings": {
        "foreground": "#88b994"
      }
    },
    {
      "name": "YAML keys",
      "scope": ["entity.name.tag.yaml"],
      "settings": {
        "foreground": "#768da1"
      }
    },
    {
      "name": "TOML keys",
      "scope": ["keyword.key.toml", "support.type.property-name.toml"],
      "settings": {
        "foreground": "#768da1"
      }
    },
    {
      "name": "TOML tables",
      "scope": ["entity.other.attribute-name.table.toml", "support.type.property-name.table.toml"],
      "settings": {
        "foreground": "#ffae00"
      }
    },
    {
      "name": "Shell variables",
      "scope": ["variable.other.normal.shell", "punctuation.definition.variable.shell"],
      "settings": {
        "foreground": "#e8575b"
      }
    },
    {
      "name": "Shell commands",
      "scope": ["support.function.builtin.shell"],
      "settings": {
        "foreground": "#768da1"
      }
    },
    {
      "name": "Type annotation punctuation",
      "scope": ["punctuation.definition.typeparameters", "meta.type.annotation"],
      "settings": {
        "foreground": "#00c4fb"
      }
    },
    {
      "name": "Namespace",
      "scope": ["entity.name.namespace", "entity.name.module"],
      "settings": {
        "foreground": "#ffae00",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust lifetime",
      "scope": ["entity.name.type.lifetime", "punctuation.definition.lifetime"],
      "settings": {
        "foreground": "#e17cb9",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust macro",
      "scope": ["entity.name.function.macro.rust", "support.macro.rust"],
      "settings": {
        "foreground": "#00c4fb"
      }
    },
    {
      "name": "Python self",
      "scope": ["variable.parameter.function.language.special.self.python"],
      "settings": {
        "foreground": "#e8575b",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Python magic methods",
      "scope": ["support.function.magic.python"],
      "settings": {
        "foreground": "#768da1",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Go package",
      "scope": ["entity.name.package.go"],
      "settings": {
        "foreground": "#ffae00"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "type": "#ffae00",
    "class": "#ffae00",
    "interface": { "foreground": "#ffae00", "italic": true },
    "enum": "#ffae00",
    "enumMember": "#b287cd",
    "struct": "#ffae00",
    "typeParameter": { "foreground": "#00c4fb", "italic": true },
    "function": "#768da1",
    "method": "#768da1",
    "macro": "#00c4fb",
    "variable": "#dac2b1",
    "variable.readonly": "#e9b76b",
    "parameter": "#ff7558",
    "property": "#dac2b1",
    "property.readonly": "#e9b76b",
    "namespace": { "foreground": "#ffae00", "italic": true },
    "decorator": "#e9b76b",
    "comment": { "foreground": "#636363", "italic": true },
    "string": "#88b994",
    "keyword": "#b287cd",
    "number": "#e9b76b",
    "regexp": "#00c4fb",
    "operator": "#dac2b1"
  }
}
