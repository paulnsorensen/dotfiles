#!/bin/bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
target_dir="$HOME/.config/ghostty"

mkdir -p "$target_dir"

# Symlink config (cmux reads from ~/.config/ghostty/config)
if [[ -L "$target_dir/config" ]]; then
  rm "$target_dir/config"
elif [[ -f "$target_dir/config" ]]; then
  mv "$target_dir/config" "$target_dir/config.bak"
  echo "Backed up existing ghostty config to config.bak"
fi

ln -s "$script_dir/config" "$target_dir/config"
echo "Linked ghostty config"
