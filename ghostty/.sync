#!/bin/bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
dotfiles_dir="$(cd "$script_dir/.." && pwd)"
target_dir="$HOME/.config/ghostty"

mkdir -p "$target_dir"

# Expand placeholders and install (same pattern as iterm2/.sync)
sed -e "s|__DOTFILES_DIR__|${dotfiles_dir}|g" \
  "$script_dir/config" > "$target_dir/config"
echo "Installed ghostty config"
