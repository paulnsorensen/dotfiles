# Font (matches iTerm2 profile)
font-family = Hack Nerd Font Mono
font-style = Regular
font-style-bold = Bold
font-style-italic = Italic
font-style-bold-italic = Bold Italic
font-size = 14

# Core colors
background = #2a1c12
foreground = #dac2b1

# Cursor
cursor-color = #dac2b1
cursor-text = #2a1c12
cursor-style = block

# Selection
selection-background = #4f4030
selection-foreground = #f8f8f8

# Background image (duck, matches iTerm2)
background-image = /Users/paul/Dev/dotfiles/iterm2/background/i_know_how_to_make_ducks.png
background-image-opacity = 0.06
background-image-position = center-left
background-blur = 20

# ANSI palette (0-7: normal, 8-15: bright)
palette = 0=#3c291c
