#!/bin/bash
# Wire up chezmoi: ensure ~/.config/chezmoi/chezmoi.toml exists with
# sourceDir pointing at this repo's chezmoi/ directory.
#
# Idempotent: writes the config exactly once, on first setup. After that
# chezmoi owns the file; this script never rewrites it. User edits to
# any keys (sourceDir, [diff], [merge], etc.) are preserved by virtue of
# never touching the file again.
#
# Atomic write via mktemp + mv -f (rename(2)) — a SIGINT mid-sync cannot
# leave chezmoi.toml empty or half-written.
#
# Owning .sync here bypasses .sync-with-rollback's default symlink path
# (see .sync-lib.sh) — the chezmoi/ source dir is referenced by absolute
# path in chezmoi.toml, not by a ~/.chezmoi symlink.

set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
config_dir="$HOME/.config/chezmoi"
config_file="$config_dir/chezmoi.toml"

if [[ -f "$config_file" ]]; then
    exit 0
fi

mkdir -p "$config_dir"
# Co-locate the tmp file with the destination so mv -f is guaranteed
# to use rename(2) (atomic). Default mktemp uses $TMPDIR, which can
# live on a different filesystem from $HOME — mv would then fall back
# to copy + unlink, reintroducing a partial-write window.
tmp_file="$(mktemp "$config_dir/chezmoi-toml.XXXXXX")"
trap 'rm -f "$tmp_file"' EXIT
cat > "$tmp_file" <<EOF
# Generated by dots sync (chezmoi/.sync) on first setup.
# chezmoi owns this file from here on — sync never rewrites it.
# Edit any key (sourceDir, [diff], [merge], etc.); your changes survive.
sourceDir = "$script_dir"
EOF
mv -f "$tmp_file" "$config_file"
