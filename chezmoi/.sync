#!/bin/bash
# Wire chezmoi for the dotfiles repo: ensure ~/.config/chezmoi/chezmoi.toml
# exists with sourceDir pointing at this directory and a [data] section the
# templates depend on.
#
# Idempotent: writes the config exactly once. After that chezmoi owns the
# file and this script never rewrites it — user edits to sourceDir, [diff],
# [merge], [data], etc. survive.
#
# Two first-run paths:
#   - TTY  → `chezmoi init --source $script_dir` renders .chezmoi.toml.tmpl
#     interactively (prompts for email + work). The template also writes
#     sourceDir so subsequent `chezmoi apply` invocations are anchored
#     correctly.
#   - No TTY (CI, automated sync) → atomic mktemp + mv writes a minimal
#     stub with sourceDir only. Templates that need [data] will fall back
#     to whatever defaults they declare; missing-required values fail loud.
#
# Owning .sync here bypasses .sync-with-rollback's default symlink path —
# chezmoi reads this dir via the absolute path written into chezmoi.toml,
# not via a ~/.chezmoi symlink.

set -euo pipefail

script_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
config_dir="$HOME/.config/chezmoi"
config_file="$config_dir/chezmoi.toml"

if [[ ! -f "$config_file" ]]; then
    mkdir -p "$config_dir"
    if command -v chezmoi &>/dev/null && [[ -t 0 ]] && [[ -f "$script_dir/.chezmoi.toml.tmpl" ]]; then
        echo "  First-run chezmoi init (prompts for email and work-machine flag)"
        # No stub fallback on init failure: this guard never re-runs once
        # chezmoi.toml exists, so a stub here would silently strand the user
        # without a [data] section and they'd never be re-prompted. Better to
        # fail loud and let them re-run dots sync.
        chezmoi init --source "$script_dir"
        echo "  Wrote chezmoi.toml from .chezmoi.toml.tmpl"
    else
        # No TTY, no chezmoi, or no template → write the minimum so
        # subsequent invocations find sourceDir. User can run
        # `chezmoi init --source $script_dir` later to populate [data].
        tmp_file=$(mktemp "$config_dir/chezmoi-toml.XXXXXX")
        trap 'rm -f "$tmp_file"' EXIT
        cat > "$tmp_file" <<EOF
# Generated by dots sync (chezmoi/.sync) on first setup.
# chezmoi owns this file from here on — sync never rewrites it.
sourceDir = "$script_dir"
EOF
        mv -f "$tmp_file" "$config_file"
        echo "  Wrote chezmoi.toml -> sourceDir=$script_dir"
    fi
fi

# Trigger chezmoi apply from this checkout so workspace syncs use the source
# tree that launched dots sync, not a stale sourceDir preserved in
# ~/.config/chezmoi/chezmoi.toml. This renders the run_onchange installers
# and templated dotfiles (gitconfig, copilot/mcp-config.json). Non-fatal — if
# chezmoi rejects the source, a required template env var is unset, or any
# other config edit fails, dots sync still wires everything else.
#
# Stream output live (sed indent, set -o pipefail preserves chezmoi's exit
# code). Some run_onchange scripts can take a while, so live output avoids an
# apparently hung dots sync.
if command -v chezmoi &>/dev/null; then
    if chezmoi --source "$script_dir" apply --force 2>&1 | sed 's/^/  /'; then
        echo "  chezmoi apply complete"
    else
        echo "  WARN: chezmoi apply failed (chezmoi-managed files may be out of sync)" >&2
    fi
else
    echo "  Skipping chezmoi apply (chezmoi not installed); chezmoi-managed files will not sync"
fi
