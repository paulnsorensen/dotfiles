#!/bin/bash
# Wire chezmoi for the dotfiles repo: ensure ~/.config/chezmoi/chezmoi.toml
# exists with sourceDir pointing at this directory.
#
# Idempotent: writes the config exactly once. After that chezmoi owns the
# file and this script never rewrites it — user edits to sourceDir, [diff],
# [merge], etc. survive.
#
# Atomic write via mktemp + mv -f. Co-located tmp file guarantees rename(2)
# semantics so a SIGINT cannot leave chezmoi.toml half-written.
#
# Owning .sync here bypasses .sync-with-rollback's default symlink path
# (see SYNC_SKIP_LIST in .sync-lib.sh) — chezmoi reads this dir via the
# absolute path written into chezmoi.toml, not via a ~/.chezmoi symlink.

set -euo pipefail

script_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
config_dir="$HOME/.config/chezmoi"
config_file="$config_dir/chezmoi.toml"

if [[ ! -f "$config_file" ]]; then
    mkdir -p "$config_dir"
    tmp_file=$(mktemp "$config_dir/chezmoi-toml.XXXXXX")
    trap 'rm -f "$tmp_file"' EXIT
    cat > "$tmp_file" <<EOF
# Generated by dots sync (chezmoi/.sync) on first setup.
# chezmoi owns this file from here on — sync never rewrites it.
sourceDir = "$script_dir"
EOF
    mv -f "$tmp_file" "$config_file"
    echo "  Wrote chezmoi.toml -> sourceDir=$script_dir"
fi

# Trigger chezmoi apply from this checkout so workspace syncs use the source
# tree that launched dots sync, not a stale sourceDir preserved in
# ~/.config/chezmoi/chezmoi.toml. Non-fatal — if chezmoi rejects the source or
# any user config edit, dots sync still wires everything else.
#
# Stream output live (sed indent, set -o pipefail preserves chezmoi's exit
# code). Some run_onchange scripts can take a while, so live output avoids an
# apparently hung dots sync.
if command -v chezmoi &>/dev/null; then
    if chezmoi --source "$script_dir" apply --force 2>&1 | sed 's/^/  /'; then
        echo "  chezmoi apply complete"
    else
        echo "  WARN: chezmoi apply failed (chezmoi-managed files may be out of sync)" >&2
    fi
else
    echo "  Skipping chezmoi apply (chezmoi not installed); chezmoi-managed files will not sync"
fi
