#!/bin/bash
# Wire up chezmoi:
#   - ~/.chezmoi → dotfiles/chezmoi (intentional symlink, not a sync side-effect)
#   - ~/.config/chezmoi/chezmoi.toml with sourceDir pointing at the symlink
#
# Owning .sync here bypasses the default sync_entry symlink path (see
# .sync-lib.sh), so the wiring is explicit and direct `chezmoi <cmd>`
# invocations resolve to the same source dir as `dots sync`.
#
# Idempotence: the chezmoi.toml file is rewritten only when its sourceDir line
# is missing or stale. User edits to other keys (e.g. [diff], [merge]) are
# preserved across runs.

set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
target_link="$HOME/.chezmoi"
config_dir="$HOME/.config/chezmoi"
config_file="$config_dir/chezmoi.toml"
desired_line="sourceDir = \"$target_link\""

if [[ -L "$target_link" ]]; then
    rm "$target_link"
elif [[ -e "$target_link" ]]; then
    echo "Refusing to replace existing $target_link (not a symlink). Move it aside and rerun." >&2
    exit 1
fi
ln -s "$script_dir" "$target_link"

mkdir -p "$config_dir"

if [[ -f "$config_file" ]] && grep -qxF "$desired_line" "$config_file"; then
    # Already correct. Don't touch the file — user edits to other keys survive.
    exit 0
fi

if [[ -f "$config_file" ]]; then
    # Stale or missing sourceDir line. Rewrite by stripping any existing
    # sourceDir entry and prepending the desired one. Everything else stays.
    tmp_file="$(mktemp)"
    grep -v '^sourceDir[[:space:]]*=' "$config_file" > "$tmp_file" || true
    {
        printf '%s\n' "$desired_line"
        cat "$tmp_file"
    } > "$config_file"
    rm -f "$tmp_file"
else
    # Fresh install. Write a minimal config with a header noting which line
    # is sync-managed.
    {
        printf '# Generated by dots sync (chezmoi/.sync).\n'
        printf '# The sourceDir line is managed by sync; other keys are user-editable.\n'
        printf '%s\n' "$desired_line"
    } > "$config_file"
fi
