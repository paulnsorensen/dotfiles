#!/bin/bash
# Wire chezmoi for the dotfiles repo: clean up legacy symlinks that the
# pre-chezmoi sync left at $HOME, ensure ~/.config/chezmoi/chezmoi.toml
# exists with sourceDir + [data], then run `chezmoi apply` against this
# checkout.
#
# First-run rules (the stub-fallback that masked bug #167 is gone):
#   - TTY  + chezmoi   → `chezmoi init` renders .chezmoi.toml.tmpl with
#                        prompts for email + work, persists [data].
#   - Non-TTY + chezmoi → fail loud. A stub without [data] would make every
#                        subsequent `chezmoi apply` error on missing-key,
#                        and there's no UI to recover. The user must re-run
#                        `dots sync` (or `chezmoi init`) from a real terminal.
#   - No chezmoi binary → exit clean; nothing reads the file.
#
# A stale stub from before this rule (sourceDir but no [data]) is detected
# and either re-initialized (TTY) or reported (non-TTY).
#
# Legacy symlink migration: pre-#167, ~/.gitconfig was a symlink into the
# dotfiles checkout. After chezmoi took ownership the target file moved but
# the dangling symlink blocked `chezmoi apply` from writing the real file.
# This script removes any chezmoi-managed path at $HOME that is a symlink
# resolving into the dotfiles checkout (whether dangling or live) so apply
# can claim it.
#
# Owning .sync here bypasses .sync's default symlink path —
# chezmoi reads this dir via the absolute path written into chezmoi.toml,
# not via a ~/.chezmoi symlink.

set -euo pipefail

script_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
dotfiles_dir=$(cd "$script_dir/.." && pwd)
config_dir="$HOME/.config/chezmoi"
config_file="$config_dir/chezmoi.toml"

# Bootstrap chezmoi on Linux when missing. chezmoi isn't in Ubuntu's apt
# and the snap channel needs root; fetch the official install script which
# drops the binary into a local bin dir with no sudo.
bootstrap_chezmoi_linux() {
    [[ "$(uname -s)" == "Linux" ]] || return 0
    command -v chezmoi &>/dev/null && return 0
    local bin_dir="$HOME/.local/bin"
    mkdir -p "$bin_dir"
    echo "  Installing chezmoi → $bin_dir (no system package available)"
    if ! curl -fsSL https://get.chezmoi.io | sh -s -- -b "$bin_dir"; then
        echo "  ERROR: chezmoi install script failed" >&2
        return 1
    fi
    hash -r 2>/dev/null || true
}
bootstrap_chezmoi_linux || exit 1

# Remove a symlink at $1 if it is dangling or resolves into the dotfiles
# checkout. Real files, dirs, and symlinks pointing elsewhere are preserved
# untouched — we only reclaim paths the pre-chezmoi sync owned.
migrate_legacy_symlink() {
    local target="$1"
    [[ -L "$target" ]] || return 0

    local link_dest abs_dest
    link_dest=$(readlink "$target")
    case "$link_dest" in
        /*) abs_dest="$link_dest" ;;
        *)  abs_dest="$(cd "$(dirname "$target")" 2>/dev/null && pwd)/$link_dest" ;;
    esac

    if [[ ! -e "$target" ]] || [[ "$abs_dest" == "$dotfiles_dir"/* ]]; then
        echo "  Removed legacy dotfiles symlink: $target -> $link_dest"
        rm -f "$target"
    fi
}

# Targets chezmoi currently renders into $HOME. Add new ones here when a
# previously-symlinked path moves under chezmoi ownership.
migrate_legacy_symlink "$HOME/.gitconfig"
migrate_legacy_symlink "$HOME/.copilot/mcp-config.json"

# Detect a stale stub: a chezmoi.toml that has sourceDir but no [data]
# block. That state is left over from the pre-fix non-TTY fallback and
# silently breaks every `chezmoi apply` from then on.
stale_stub=false
if [[ -f "$config_file" ]] && ! grep -q '^\[data\]' "$config_file"; then
    stale_stub=true
fi

if $stale_stub; then
    if command -v chezmoi &>/dev/null && [[ -t 0 ]] && [[ -f "$script_dir/.chezmoi.toml.tmpl" ]]; then
        echo "  Detected stale chezmoi.toml stub (no [data]); re-running chezmoi init"
        rm -f "$config_file"
    else
        echo "  ERROR: chezmoi.toml has no [data] block — chezmoi apply will fail." >&2
        echo "  Re-run 'dots sync' from a real terminal to repopulate the prompts," >&2
        echo "  or delete $config_file and run 'chezmoi init --source $script_dir'." >&2
        exit 1
    fi
fi

if [[ ! -f "$config_file" ]]; then
    if ! command -v chezmoi &>/dev/null; then
        # No chezmoi → nothing reads chezmoi.toml; do not write a stub.
        echo "  Skipping chezmoi setup (chezmoi not installed)"
        exit 0
    fi

    mkdir -p "$config_dir"

    if [[ ! -t 0 ]] && [[ -f "$script_dir/.chezmoi.toml.tmpl" ]]; then
        echo "  ERROR: chezmoi.toml is missing and no TTY available to run init." >&2
        echo "  Re-run 'dots sync' (or 'chezmoi init --source $script_dir')" >&2
        echo "  from a real terminal so the first-time prompts can fire." >&2
        exit 1
    fi

    if [[ -f "$script_dir/.chezmoi.toml.tmpl" ]]; then
        echo "  First-run chezmoi init (prompts for email and work-machine flag)"
        chezmoi init --source "$script_dir"
        echo "  Wrote chezmoi.toml from .chezmoi.toml.tmpl"
    else
        # No template means we're operating on a partial checkout. Write the
        # minimum so subsequent apply runs find sourceDir; apply will still
        # fail without [data] but the failure is loud and obvious.
        cat > "$config_file" <<EOF
# Generated by dots sync (chezmoi/.sync) on first setup.
sourceDir = "$script_dir"
EOF
        echo "  Wrote chezmoi.toml -> sourceDir=$script_dir (no template found)"
    fi
fi

# (prelink_claude_writethrough retired: ~/.claude/{hooks,reference} are now
# chezmoi-managed exact_ dirs assembled below — no write-through symlinks.
# run_once_before_migrate-ap-claude.sh unlinks any legacy symlink.)

# Assemble the registry-selected ~/.claude payload (skills/agents/commands/
# hooks/lib/reference/workflows) into dot_claude/exact_* source state so the
# apply below deploys it with deletion propagation. Fail loud — an incomplete
# assembly must not silently apply a partial exact_ tree (which would DELETE
# live entries).
# shellcheck source=../.sync-lib.sh
source "$dotfiles_dir/.sync-lib.sh"
if ! sync_claude_chezmoi_sources "$dotfiles_dir" "$script_dir"; then
    echo "  ERROR: claude chezmoi source assembly failed — aborting chezmoi apply" >&2
    exit 1
fi

# Trigger chezmoi apply from this checkout so workspace syncs use the source
# tree that launched dots sync, not a stale sourceDir preserved in
# ~/.config/chezmoi/chezmoi.toml. Partial-OK — we don't abort the rest of
# dots sync if chezmoi fails, but we DO propagate the failure as our exit
# code so .sync-lib.sh records us in SYNC_FAILURES and .sync
# surfaces it in the final summary. Silent partial-install regressions are
# what trapped a missing SessionStart hook for hours.
#
# Stream output live (sed indent, set -o pipefail preserves chezmoi's exit
# code). Some run_onchange scripts can take a while, so live output avoids
# an apparently hung dots sync.
chezmoi_status=0
if command -v chezmoi &>/dev/null; then
    if chezmoi --source "$script_dir" apply --force 2>&1 | sed 's/^/  /'; then
        echo "  chezmoi apply complete"
    else
        chezmoi_status=$?
        echo "  ERROR: chezmoi apply failed (exit $chezmoi_status) — alphabetically-later run_onchange installers were skipped" >&2
        echo "         See the specific error above for the cause. Common ones:" >&2
        echo "           • settings.json unknown-key halt → fold the key into chezmoi/lib/claude-settings-authoritative.json or chezmoi/.chezmoidata/claude.yaml" >&2
        echo "           • 'gh auth status' failing → run 'gh auth login', then re-run 'dots sync'." >&2
    fi
else
    echo "  Skipping chezmoi apply (chezmoi not installed); chezmoi-managed files will not sync"
fi

exit "$chezmoi_status"
