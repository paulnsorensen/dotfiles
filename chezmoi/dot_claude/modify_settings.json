#!/bin/sh
# Make ~/.claude/settings.json fully repo-authoritative on every `chezmoi apply`.
#
#   stdin  = current live file contents (empty on a fresh machine)
#   stdout = the new file contents chezmoi writes back
#
# The desired file is composed from two committed sources:
#   * $CHEZMOI_SOURCE_DIR/lib/claude-settings-authoritative.json — static
#     repo-owned keys (model, effortLevel, env, sandbox, theme, ...).
#   * $CHEZMOI_SOURCE_DIR/.chezmoidata/claude.yaml — the claude registry;
#     authors `hooks`, `enabledPlugins`, `extraKnownMarketplaces`, and
#     `permissions.allow/deny/ask/additionalDirectories`.
#
# EVERY managed key is overwritten from source — live drift (in-app /model
# changes, session-granted permissions, in-app plugin toggles) is discarded.
# Promote anything you want to keep into the registry, then `dots sync`.
#
# Unknown-key halt gate: any live key-path outside the desired document's
# schema is a key the app introduced. The script prints it and EXITS NON-ZERO,
# which halts `chezmoi apply` and leaves the live file untouched — a new
# Claude Code key/format is surfaced (fold it into the authoritative source or
# the registry) instead of being silently clobbered. `enabledPlugins` and
# `extraKnownMarketplaces` subtrees are exempt (their keys are dynamic plugin
# names, not schema) — live entries there are wiped, not halted on.
#
# ${HOME} in registry string values is expanded here — needed for keys Claude
# reads as literal JSON (e.g. marketplace directory paths).

set -eu

AUTH="${CHEZMOI_SOURCE_DIR:?CHEZMOI_SOURCE_DIR is unset}/lib/claude-settings-authoritative.json"
REG="$CHEZMOI_SOURCE_DIR/.chezmoidata/claude.yaml"

live=$(cat)

# Missing jq/yq: don't corrupt the file. Keep the live copy if present, else
# emit the static authoritative source. Both are in packages.yaml, so this
# only guards an unusual partial-bootstrap environment.
for tool in jq yq; do
    if ! command -v "$tool" >/dev/null 2>&1; then
        echo "modify_settings.json: $tool missing — Claude settings not enforced this sync" >&2
        if [ -n "$live" ]; then printf '%s' "$live"; else cat "$AUTH"; fi
        exit 0
    fi
done

for src in "$AUTH" "$REG"; do
    if [ ! -f "$src" ]; then
        echo "modify_settings.json: source missing: $src" >&2
        exit 1
    fi
done

# Compose the desired document: static authoritative keys + registry-authored
# keys. permissions merges defaultMode (static) with the registry lists.
desired=$(
    yq -o=json '.claude' "$REG" | jq --slurpfile auth "$AUTH" --arg home "$HOME" '
        def expand: walk(if type == "string" then gsub("\\$\\{HOME\\}"; $home) else . end);
        . as $reg | ($auth[0]) as $a
        | $a
        + { hooks:                  (($reg.hooks // {}) | expand),
            enabledPlugins:         ($reg.enabledPlugins // {}),
            extraKnownMarketplaces: (($reg.extraKnownMarketplaces // {}) | expand),
            permissions: ( ($a.permissions // {}) + {
                allow:                 ($reg.permissions.allow // []),
                deny:                  ($reg.permissions.deny // []),
                ask:                   ($reg.permissions.ask // []),
                additionalDirectories: ($reg.permissions.additionalDirectories // []) } ) }
    '
)

# Fresh machine (empty stdin): emit the desired document.
if [ -z "$live" ]; then
    printf '%s\n' "$desired"
    exit 0
fi

# Corrupt or non-object live file: halt with guidance instead of an opaque jq
# parse error under set -eu.
if ! printf '%s' "$live" | jq -e 'type == "object"' >/dev/null 2>&1; then
    echo "modify_settings.json: live ~/.claude/settings.json is not a JSON object" >&2
    echo "  (corrupt or truncated). Fix or remove it, then re-run dots sync." >&2
    exit 1
fi

# ── unknown-key gate ─────────────────────────────────────────────────
# A live key-path is "known" when its object-key signature (array indices
# dropped, so a value change or an extra list entry never counts as a new
# key) is a path present in the desired document, OR it sits under a
# dynamic-key subtree (enabledPlugins / extraKnownMarketplaces). We enumerate
# every live node-path (not just scalar leaves) so a new key whose value is an
# empty object/array or null is caught too.
unknown=$(
    printf '%s' "$live" | jq -r --argjson desired "$desired" '
        def sig: [ .[] | strings ];
        [ ["enabledPlugins"], ["extraKnownMarketplaces"] ] as $dyn
        | ([ $desired | paths | sig ] | unique) as $known
        | [ paths | sig ]
        | map(select(
              . as $p
              | (($known | any(. == $p)) | not)
              and ([ $dyn[] | . as $pre | ($p[0:($pre | length)] == $pre) ] | any | not)
          ))
        | unique
        | map(join("."))
        | .[]
    '
)

if [ -n "$unknown" ]; then
    {
        echo "Claude settings.json has key-path(s) the repo does not know about:"
        printf '%s\n' "$unknown" | sed 's/^/  + /'
        echo
        echo "Claude Code likely introduced these. Fold each into the authoritative"
        echo "source or the claude registry, then re-run dots sync:"
        echo "  $AUTH"
        echo "  $REG"
    } >&2
    exit 1
fi

# ── write ────────────────────────────────────────────────────────────────────
# No merge: the desired document IS the file. Live drift on managed keys is
# wiped by design (promote keepers to the registry).
printf '%s\n' "$desired"
