#!/bin/sh
# Make ~/.claude/settings.json fully repo-authoritative on every `chezmoi apply`.
#
#   stdin  = current live file contents (empty on a fresh machine)
#   stdout = the new file contents chezmoi writes back
#
# The desired file is composed from four committed sources:
#   * $CHEZMOI_SOURCE_DIR/lib/claude-settings-authoritative.json — static
#     repo-owned keys (model, effortLevel, env, sandbox, theme, ...).
#   * $CHEZMOI_SOURCE_DIR/.chezmoidata/claude.yaml — the claude registry;
#     authors `hooks`, `enabledPlugins`, `extraKnownMarketplaces`, and
#     `permissions.allow/deny/ask/additionalDirectories`.
#   * $CHEZMOI_SOURCE_DIR/../claude/plugins/registry.yaml — the plugin
#     registry; gate-filtered at apply time and overlaid onto the claude.yaml
#     `enabledPlugins` / `extraKnownMarketplaces` keys. This script is the
#     SINGLE writer of those settings.json keys — claude/plugins/sync.sh no
#     longer touches settings.json (it only installs/removes plugin payloads
#     and registers local marketplaces with the CLI). A gate passes when its
#     env var is "true" (gate vars are exported by `dots` from .env before
#     `chezmoi apply`); unset gates are treated as closed. If the registry is
#     missing, composition falls back to claude.yaml only (with a warning).
#   * $CHEZMOI_SOURCE_DIR/../agents/plugins/registry.yaml — the cross-harness
#     plugin registry. Native-claude entries (resolved `native:` set includes
#     claude) overlay their marketplace + enabledPlugins entry, keyed by the
#     marketplace.json `.name` (may differ from the YAML key). git: entries
#     root at ~/.cache/ap/plugins/<key>; path: entries at the expanded path. A
#     missing plugin cache warns and skips (the sync clones it later; the next
#     apply converges). This native path is never gated.
#
# EVERY managed key is overwritten from source — live drift (in-app /model
# changes, session-granted permissions, in-app plugin toggles) is discarded.
# Promote anything you want to keep into the registry, then `dots sync`.
#
# Unknown-key halt gate: any live key-path outside the desired document's
# schema is a key the app introduced. The script prints it and EXITS NON-ZERO,
# which halts `chezmoi apply` and leaves the live file untouched — a new
# Claude Code key/format is surfaced (fold it into the authoritative source or
# the registry) instead of being silently clobbered. `enabledPlugins` and
# `extraKnownMarketplaces` subtrees are exempt (their keys are dynamic plugin
# names, not schema) — live entries there are wiped, not halted on.
#
# ${HOME} in registry string values is expanded here — needed for keys Claude
# reads as literal JSON (e.g. marketplace directory paths).

set -eu

AUTH="${CHEZMOI_SOURCE_DIR:?CHEZMOI_SOURCE_DIR is unset}/lib/claude-settings-authoritative.json"
REG="$CHEZMOI_SOURCE_DIR/.chezmoidata/claude.yaml"

live=$(cat)

# Missing jq/yq: don't corrupt the file. Keep the live copy if present, else
# emit the static authoritative source. Both are in packages.yaml, so this
# only guards an unusual partial-bootstrap environment.
for tool in jq yq; do
    if ! command -v "$tool" >/dev/null 2>&1; then
        echo "modify_settings.json: $tool missing — Claude settings not enforced this sync" >&2
        if [ -n "$live" ]; then printf '%s' "$live"; else cat "$AUTH"; fi
        exit 0
    fi
done

for src in "$AUTH" "$REG"; do
    if [ ! -f "$src" ]; then
        echo "modify_settings.json: source missing: $src" >&2
        exit 1
    fi
done

# ── plugin-registry overlay ────────────────────────────────────────────────
# Compose the gate-filtered plugin overlay for enabledPlugins /
# extraKnownMarketplaces. A gate passes when its env var is "true"; unset is
# closed. Marketplaces are only overlaid for one-plugin-per-marketplace entries
# (mp name == plugin name) that carry a path — the same constraint sync.sh
# applies. If the registry is missing, the overlay stays empty and composition
# falls back to claude.yaml alone.
PLUGIN_REG="$CHEZMOI_SOURCE_DIR/../claude/plugins/registry.yaml"
# `$g` is a jq variable, not a shell var — single quotes are intentional.
# shellcheck disable=SC2016
gate_filter='select((.value.gate // "") as $g | $g == "" or (env[$g] // "false") == "true")'

# Gate-filtered {plugin: load} map from the plugin registry.
plugin_reg_enabled() {
    yq -o=json '.plugins' "$PLUGIN_REG" \
        | jq "[ to_entries[] | $gate_filter | {(.key): (.value.load // false)} ] | add // {}"
}

# Gate-filtered marketplace overlay: one-plugin-per-marketplace entries with a
# path, resolved to absolute and skipped when the dir is absent. Kept in a
# function so the case statement is NOT parsed inside a $() (bash miscounts the
# case-pattern parens there).
plugin_reg_marketplaces() {
    # Every /bin/sh this repo targets (macOS bash, dash) implements `local`.
    # shellcheck disable=SC3043
    local repo_root mp_name mp_path abs_path
    repo_root=$(cd "$CHEZMOI_SOURCE_DIR/.." && pwd)
    yq -o=json '.plugins' "$PLUGIN_REG" \
        | jq -r "to_entries[] | $gate_filter | select(.value.path)
                 | (.key | split(\"@\")) as \$p | select(\$p[0] == \$p[1])
                 | \$p[1] + \"\t\" + .value.path" \
        | while IFS="$(printf '\t')" read -r mp_name mp_path; do
            [ -z "$mp_name" ] && continue
            # shellcheck disable=SC2088  # literal "~/" pattern, expanded explicitly below
            case "$mp_path" in
                "~/"*) abs_path="$HOME/${mp_path#"~/"}" ;;
                /*)    abs_path="$mp_path" ;;
                *)     abs_path="$repo_root/$mp_path" ;;
            esac
            if [ ! -d "$abs_path" ]; then
                echo "modify_settings.json: skipping $mp_name marketplace, path not found: $abs_path" >&2
                continue
            fi
            jq -n --arg n "$mp_name" --arg p "$abs_path" \
                '{($n): {source: {source: "directory", path: $p}}}'
        done | jq -s 'add // {}'
}

# ── native-plugin overlay (cross-harness registry) ─────────────────────────
NATIVE_REG="$CHEZMOI_SOURCE_DIR/../agents/plugins/registry.yaml"

# Native-claude overlay: entries whose resolved `native:` set includes claude
# get their marketplace + enabledPlugins entry, keyed by the marketplace.json
# `.name` (authoritative; may differ from the YAML key). git: entries root at
# ~/.cache/ap/plugins/<key>; path: entries at the expanded path (~/, absolute,
# or repo-relative). A missing cache / marketplace.json warns and skips (never
# fails the apply). Emits one JSON object {enabled:{...}, marketplaces:{...}}.
native_plugin_overlays() {
    # shellcheck disable=SC3043
    local repo_root key kind rawpath root mp_json name
    repo_root=$(cd "$CHEZMOI_SOURCE_DIR/.." && pwd)
    yq -o=json '.plugins' "$NATIVE_REG" \
        | jq -r '
            ["claude","codex","copilot"] as $drivable
            | to_entries[] | .key as $key | .value as $v
            | ( if ($v.native == true)
                    then (($v.harnesses // []) - (($v.harnesses // []) - $drivable))
                elif (($v.native | type) == "array") then $v.native
                else [] end
              ) as $nat0
            | ($nat0 + (if $v.claude_native == true then ["claude"] else [] end)) as $nat
            | select($nat | index("claude"))
            | if $v.git then [$key, "git", ""]
              elif $v.path then [$key, "path", $v.path]
              else empty end
            | @tsv' \
        | while IFS="$(printf '\t')" read -r key kind rawpath; do
            [ -z "$key" ] && continue
            case "$kind" in
                git) root="$HOME/.cache/ap/plugins/$key" ;;
                path)
                    # shellcheck disable=SC2088  # literal "~/" expanded below
                    case "$rawpath" in
                        "~/"*) root="$HOME/${rawpath#"~/"}" ;;
                        /*)    root="$rawpath" ;;
                        *)     root="$repo_root/$rawpath" ;;
                    esac
                    ;;
            esac
            mp_json="$root/.claude-plugin/marketplace.json"
            if [ ! -f "$mp_json" ]; then
                echo "modify_settings.json: skipping native plugin $key, marketplace.json not found: $mp_json" >&2
                continue
            fi
            name=$(jq -r '.name // empty' "$mp_json")
            if [ -z "$name" ]; then
                echo "modify_settings.json: skipping native plugin $key, marketplace.json has no .name: $mp_json" >&2
                continue
            fi
            jq -n --arg k "$key" --arg n "$name" --arg p "$root" \
                '{enabled: {("\($k)@\($n)"): true}, marketplaces: {($n): {source: {source: "directory", path: $p}}}}'
        done | jq -s '{enabled: (map(.enabled) | add // {}), marketplaces: (map(.marketplaces) | add // {})}'
}

reg_enabled='{}'
reg_marketplaces='{}'
if [ -f "$PLUGIN_REG" ]; then
    reg_enabled=$(plugin_reg_enabled)
    reg_marketplaces=$(plugin_reg_marketplaces)
else
    echo "modify_settings.json: plugin registry not found: $PLUGIN_REG — composing enabledPlugins/extraKnownMarketplaces from claude.yaml only" >&2
fi

native_enabled='{}'
native_marketplaces='{}'
if [ -f "$NATIVE_REG" ]; then
    native_overlays=$(native_plugin_overlays)
    native_enabled=$(printf '%s' "$native_overlays" | jq '.enabled')
    native_marketplaces=$(printf '%s' "$native_overlays" | jq '.marketplaces')
else
    echo "modify_settings.json: native plugin registry not found: $NATIVE_REG — no native-claude overlay" >&2
fi

# Compose the desired document: static authoritative keys + registry-authored
# keys. permissions merges defaultMode (static) with the registry lists.
# enabledPlugins / extraKnownMarketplaces are claude.yaml base + the
# gate-filtered plugin-registry overlay (registry wins on key collision).
desired=$(
    yq -o=json '.claude' "$REG" | jq \
        --slurpfile auth "$AUTH" --arg home "$HOME" \
        --argjson reg_enabled "$reg_enabled" \
        --argjson reg_marketplaces "$reg_marketplaces" \
        --argjson native_enabled "$native_enabled" \
        --argjson native_marketplaces "$native_marketplaces" '
        def expand: walk(if type == "string" then gsub("\\$\\{HOME\\}"; $home) else . end);
        . as $reg | ($auth[0]) as $a
        | $a
        + { hooks:                  (($reg.hooks // {}) | expand),
            enabledPlugins:         (($reg.enabledPlugins // {}) + $reg_enabled + $native_enabled),
            extraKnownMarketplaces: ((($reg.extraKnownMarketplaces // {}) | expand) + $reg_marketplaces + $native_marketplaces),
            permissions: ( ($a.permissions // {}) + {
                allow:                 ($reg.permissions.allow // []),
                deny:                  ($reg.permissions.deny // []),
                ask:                   ($reg.permissions.ask // []),
                additionalDirectories: ($reg.permissions.additionalDirectories // []) } ) }
    '
)

# env.SSL_CERT_FILE is a macOS-only pin (dc42ae5): the Seatbelt sandbox blocks
# Keychain access, so OpenSSL-linked tools need /etc/ssl/cert.pem spelled out.
# That path does not exist on Linux and poisons TLS for anything honoring the
# var (npx, curl, Go) — drop the key on non-Darwin. The unknown-key gate below
# still treats a live copy as known so the transition sync wipes it, not halts.
if [ "$(uname -s)" != "Darwin" ]; then
    desired=$(printf '%s' "$desired" | jq 'del(.env.SSL_CERT_FILE)')
fi

# Fresh machine (empty stdin): emit the desired document.
if [ -z "$live" ]; then
    printf '%s\n' "$desired"
    exit 0
fi

# Corrupt or non-object live file: halt with guidance instead of an opaque jq
# parse error under set -eu.
if ! printf '%s' "$live" | jq -e 'type == "object"' >/dev/null 2>&1; then
    echo "modify_settings.json: live ~/.claude/settings.json is not a JSON object" >&2
    echo "  (corrupt or truncated). Fix or remove it, then re-run dots sync." >&2
    exit 1
fi

# ── unknown-key gate ─────────────────────────────────────────────────
# A live key-path is "known" when its object-key signature (array indices
# dropped, so a value change or an extra list entry never counts as a new
# key) is a path present in the desired document, OR it sits under a
# dynamic-key subtree (enabledPlugins / extraKnownMarketplaces). We enumerate
# every live node-path (not just scalar leaves) so a new key whose value is an
# empty object/array or null is caught too.
unknown=$(
    printf '%s' "$live" | jq -r --argjson desired "$desired" '
        def sig: [ .[] | strings ];
        [ ["enabledPlugins"], ["extraKnownMarketplaces"] ] as $dyn
        | (([ $desired | paths | sig ] + [["env","SSL_CERT_FILE"]]) | unique) as $known
        | [ paths | sig ]
        | map(select(
              . as $p
              | (($known | any(. == $p)) | not)
              and ([ $dyn[] | . as $pre | ($p[0:($pre | length)] == $pre) ] | any | not)
          ))
        | unique
        | map(join("."))
        | .[]
    '
)

if [ -n "$unknown" ]; then
    {
        echo "Claude settings.json has key-path(s) the repo does not know about:"
        printf '%s\n' "$unknown" | sed 's/^/  + /'
        echo
        echo "Claude Code likely introduced these. Fold each into the authoritative"
        echo "source or the claude registry, then re-run dots sync:"
        echo "  $AUTH"
        echo "  $REG"
    } >&2
    exit 1
fi

# ── write ────────────────────────────────────────────────────────────────────
# No merge: the desired document IS the file. Live drift on managed keys is
# wiped by design (promote keepers to the registry).
printf '%s\n' "$desired"
