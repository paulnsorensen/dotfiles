#!/bin/bash
# run_onchange — re-runs whenever the dotfiles skills tree changes.
#
# The skills source-tree hash below is embedded by chezmoi at template render
# time. chezmoi hashes the *rendered* script; whenever the embedded hash
# changes, chezmoi reruns this script.
#
# Hash strategy: walk the working tree (not the git index), sort the file
# list for determinism, then shasum file contents. Captures unstaged edits
# the index hash would miss, and produces the same digest across machines.
# Hashing every file under skills/ (including _registry.yaml) means registry
# edits trigger reruns too.
#
# Skills tree hash: {{ output "sh" "-c" (printf "find %q/../skills -type f -not -name .DS_Store -print0 2>/dev/null | LC_ALL=C sort -z | xargs -0 shasum -a 256 2>/dev/null | shasum -a 256 | cut -d' ' -f1" .chezmoi.sourceDir) }}

set -euo pipefail

SOURCE_DIR="{{ .chezmoi.sourceDir }}"
DOTFILES_ROOT="$SOURCE_DIR/.."

# Phase 1: dotfiles-owned skills → ~/.claude/skills (always runs).
"$SOURCE_DIR/lib/install-local.sh" \
    "$DOTFILES_ROOT/skills" \
    "$HOME/.claude/skills"

# Phase 2: external skills via `gh skill install` — required, not best-effort.
# Failure aborts the sync so silent partial-install regressions can't reoccur.
if ! command -v gh &>/dev/null; then
    echo "Error: gh CLI not found. Install with: brew install gh" >&2
    exit 1
fi
if ! gh skill --help &>/dev/null; then
    echo "Error: 'gh skill' subcommand unavailable. Upgrade gh to v2.90+." >&2
    exit 1
fi
if ! gh auth status &>/dev/null; then
    echo "Error: gh is not authenticated. Run: gh auth login" >&2
    exit 1
fi
"$SOURCE_DIR/lib/install-external.sh" "$DOTFILES_ROOT/skills/_registry.yaml"
