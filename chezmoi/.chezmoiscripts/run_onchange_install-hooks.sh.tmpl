#!/bin/bash
# run_onchange — re-runs whenever any harness-agnostic hook asset changes.
#
# Reruns when agents/hooks/, agents/lib/cheese-flair.sh, or
# agents/reference/cheese-flair.md change. The hash below is computed by
# chezmoi at template render time over the rendered script; chezmoi reruns
# whenever the embedded hash changes.
#
# Hooks asset hash: {{ output "sh" "-c" (printf "{ find %q/../agents/hooks -type f -not -name .DS_Store -print0 2>/dev/null; printf '\\0%%s' %q/../agents/lib/cheese-flair.sh %q/../agents/reference/cheese-flair.md; } | LC_ALL=C sort -z | xargs -0 shasum -a 256 2>/dev/null | shasum -a 256 | cut -d' ' -f1" .chezmoi.sourceDir .chezmoi.sourceDir .chezmoi.sourceDir) }}

set -euo pipefail

SOURCE_DIR="{{ .chezmoi.sourceDir }}"
DOTFILES_ROOT="$SOURCE_DIR/.."
INSTALLER="$SOURCE_DIR/lib/install-shared-assets.sh"
SYNC_SCRIPT="$DOTFILES_ROOT/agents/hooks/sync.sh"

# Copy the hook script, the lib, and the bank into each harness's home so
# the self-locating preamble in the hook script resolves correctly under
# both ~/.claude and ~/.codex.
"$INSTALLER" "$DOTFILES_ROOT/agents/hooks/session-start-cheese-flair.sh" \
    "$HOME/.claude/hooks/session-start-cheese-flair.sh" \
    "$HOME/.codex/hooks/session-start-cheese-flair.sh"

"$INSTALLER" "$DOTFILES_ROOT/agents/lib/cheese-flair.sh" \
    "$HOME/.claude/lib/cheese-flair.sh" \
    "$HOME/.codex/lib/cheese-flair.sh"

"$INSTALLER" "$DOTFILES_ROOT/agents/reference/cheese-flair.md" \
    "$HOME/.claude/reference/cheese-flair.md" \
    "$HOME/.codex/reference/cheese-flair.md"

# Reconcile claude/settings.json + ~/.codex/config.toml against the
# registry. The sync is purely additive and idempotent (no removal
# prompts), so no --force flag is needed.
bash "$SYNC_SCRIPT"
