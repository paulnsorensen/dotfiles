#!/bin/bash
# run_onchange — keeps the hallouminate nightly binary current and deploys its
# plugin across the harnesses declared in agents/plugins/registry.yaml.
#
# Binary delivery mirrors run_onchange_after_install-tilth.sh.tmpl. The npm
# package contains only the platform binary installer, so plugin delivery uses
# a separately refreshed git cache: native marketplace installs for Claude Code,
# Codex, and Copilot; decomposed MCP/skills for opencode, Cursor, and Crush.
#
# Re-trigger markers: the npm nightly version and helper body. The inner
# version probe ends in echo so an offline template render remains stable.
# latest nightly version: {{ output "sh" "-c" "npm view @paulnsorensen/hallouminate-nightly version 2>/dev/null | tr -d '[:space:]'; echo" }}
# helper hash: {{ output "sh" "-c" (printf "shasum -a 256 %q/lib/hallouminate-install.sh 2>/dev/null | cut -d' ' -f1" .chezmoi.sourceDir) }}

set -euo pipefail

SOURCE_DIR="{{ .chezmoi.sourceDir }}"
# shellcheck source=../lib/hallouminate-install.sh
# shellcheck disable=SC1091
source "$SOURCE_DIR/lib/hallouminate-install.sh"

hallouminate_install_nightly
hallouminate_sync_plugins "$HOME/.cache/ap/plugins/hallouminate"
