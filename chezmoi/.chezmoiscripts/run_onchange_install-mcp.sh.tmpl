#!/bin/bash
# run_onchange — re-runs whenever the MCP registry changes.
#
# Reruns when agents/mcp/registry.yaml changes. The hash below is computed
# by chezmoi at template render time over the rendered script; chezmoi reruns
# whenever the embedded hash changes.
#
# Running non-interactively from chezmoi, we pass --force so drift entries are
# removed without prompting. The interactive form lives behind the `mcp-sync`
# zsh alias for ad-hoc runs.
#
# MCP registry hash: {{ output "sh" "-c" (printf "shasum -a 256 %q/../agents/mcp/registry.yaml 2>/dev/null | cut -d' ' -f1" .chezmoi.sourceDir) }}

set -euo pipefail

SOURCE_DIR="{{ .chezmoi.sourceDir }}"
DOTFILES_ROOT="$SOURCE_DIR/.."
SYNC_SCRIPT="$DOTFILES_ROOT/agents/mcp/sync.sh"

# Skip entirely if neither harness CLI is on PATH — saves a noisy block on
# fresh machines before `dots sync` finishes installing brew packages.
if ! command -v claude &>/dev/null && ! command -v codex &>/dev/null; then
    echo "  Skipping MCP sync (no harness CLI found)"
    exit 0
fi

bash "$SYNC_SCRIPT" --force
