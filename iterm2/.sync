#!/bin/bash

if [[ "$(uname)" != "Darwin" ]]; then
  echo "Not on mac, skipping iterm2"
  exit 0
fi

if [[ "${QUICK_SYNC:-false}" == "true" ]]; then
  echo "Quick sync, skipping iterm"
  exit 0
fi

set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
dotfiles_dir="$(cd "$script_dir/.." && pwd)"
live_plist="$script_dir/com.googlecode.iterm2.plist"
base_plist="$script_dir/iterm2.base.plist"
dynamic_yaml="$script_dir/dynamic.yaml"

# ── Background image ──────────────────────────────────────────────────────
bg_link=https://u2658847.dl.dropboxusercontent.com/u/2658847/IMG_0568.JPG
bg_opacity=50%

if [[ ! -f "$script_dir/background/i_know_how_to_make_ducks.png" ]]; then
    echo "Downloading background file..."
    wget -O "$script_dir/background/i_know_how_to_make_ducks.png" "$bg_link"
    echo "Setting opacity of background file..."
    convert "$script_dir/background/i_know_how_to_make_ducks.png" \
      -alpha on -channel A -evaluate set "$bg_opacity" +channel \
      "$script_dir/background/i_know_how_to_make_ducks.png"
fi

# ── Generate live plist from base ─────────────────────────────────────────
if [[ ! -f "$base_plist" ]]; then
  echo "No base plist found — run 'bash iterm2/.scrub' first"
  exit 1
fi

# Expand placeholders in base → live plist
sed \
  -e "s|__DOTFILES_DIR__|${dotfiles_dir}|g" \
  -e "s|__HOME__|${HOME}|g" \
  "$base_plist" > "$live_plist"

echo "Loading iterm2 configuration"

# ── Apply dynamic patches from YAML ──────────────────────────────────────
if [[ -f "$dynamic_yaml" ]] && command -v yq &>/dev/null; then
  export DOTFILES_DIR="$dotfiles_dir"
  count=$(yq '.patches | length' "$dynamic_yaml")
  for ((i = 0; i < count; i++)); do
    keypath=$(yq ".patches[$i].keypath" "$dynamic_yaml")
    raw_value=$(yq ".patches[$i].value" "$dynamic_yaml")
    # Expand $HOME and $DOTFILES_DIR in values (single quotes intentional for envsubst)
    # shellcheck disable=SC2016
    value=$(echo "$raw_value" | envsubst '$DOTFILES_DIR $HOME')
    /usr/libexec/PlistBuddy -c "Set '${keypath}' '${value}'" "$live_plist" 2>/dev/null \
      || echo "  Warning: failed to set ${keypath}"
  done
fi

# ── Tell iTerm2 to use this directory ─────────────────────────────────────
defaults write com.googlecode.iterm2.plist PrefsCustomFolder -string "$script_dir"
defaults write com.googlecode.iterm2.plist LoadPrefsFromCustomFolder -bool true
