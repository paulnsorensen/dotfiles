#!/bin/bash
# Sync yazi config to ~/.config/yazi/

DEST="$HOME/.config/yazi"
SOURCE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

mkdir -p "$(dirname "$DEST")"

if [[ -L "$DEST" ]]; then
    rm "$DEST"
elif [[ -d "$DEST" ]]; then
    rm -rf "$DEST.bak" 2>/dev/null || true
    mv "$DEST" "$DEST.bak"
fi

ln -s "$SOURCE_DIR" "$DEST"
echo "  yazi config synced"
