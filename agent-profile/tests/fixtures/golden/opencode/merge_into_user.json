{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-5",
  "mcp": {
    "user-mcp": {
      "type": "local",
      "enabled": true,
      "command": [
        "my-tool"
      ]
    },
    "serena": {
      "type": "local",
      "enabled": true,
      "command": [
        "serena",
        "start-mcp-server"
      ]
    }
  },
  "permission": {
    "bash": {
      "npm *": "allow",
      "cargo *": "allow",
      "Edit": "allow",
      "git push origin main": "allow"
    },
    "read": {
      "./src": "allow"
    },
    "edit": {
      "./secrets": "deny"
    },
    "serena_find_symbol": "deny"
  }
}
