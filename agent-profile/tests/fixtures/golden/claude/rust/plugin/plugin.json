{
  "name": "rust",
  "version": "1.0.0",
  "description": "Rust toolchain conventions, clippy command, idiomatic reviewer",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/cargo-check.sh"
          }
        ]
      }
    ]
  }
}
