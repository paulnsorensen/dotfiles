#!/bin/bash
# Sync zellij config to ~/.config/zellij/

DEST="$HOME/.config/zellij"
SOURCE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ -L "$DEST" ]]; then
    rm "$DEST"
elif [[ -d "$DEST" ]]; then
    mv "$DEST" "$DEST.bak"
fi

ln -s "$SOURCE_DIR" "$DEST"
echo "  zellij config synced"
