#!/usr/bin/env bash
# cc-session-name — print a collision-safe tmux session name for a path.
#
#   <repo>/.worktrees/<slug>  -> "<repo>-<slug>"   (worktree, or any subdir of it)
#   inside a git repo         -> "<repo>"          (toplevel basename, any subdir)
#   anywhere else             -> basename of path
#
# Dots and colons become hyphens (tmux session names can't contain them).
# The path is first resolved to its git worktree/repo root, so a subdir collapses
# to the same session as its root (de-sprawl). A worktree's own toplevel IS the
# worktree dir, whose path carries /.worktrees/<slug> — that's how repo+slug are
# recovered without colliding across repos.
set -euo pipefail

path="${1:-$PWD}"
path="${path%/}"

sanitize() {
    local s="$1"
    s="${s//./-}"
    s="${s//:/-}"
    printf '%s' "$s"
}

# Collapse to the git root when inside a repo; otherwise take the path as given.
if root="$(git -C "$path" rev-parse --show-toplevel 2>/dev/null)"; then
    base="$root"
else
    base="$path"
fi

if [[ "$base" == */.worktrees/* ]]; then
    slug="${base##*/}"
    repo_path="${base%/.worktrees/*}"
    sanitize "${repo_path##*/}-${slug}"
else
    sanitize "${base##*/}"
fi
