#!/bin/bash
# lspmux-wrap — LSP binary interceptor
#
# Usage: lspmux-wrap <binary-name> [args...]
#
# Called by shadow wrappers (pyright-langserver, gopls, etc.).
# Finds the real LSP binary and forwards through lspmux client.
# Fails loudly if lspmux is not installed or the server is down.
#
# Stripping $DOTFILES_DIR/bin from PATH prevents infinite recursion — without
# this, `command -v pyright-langserver` would find this wrapper again.

set -euo pipefail

BINARY="${1:-}"
if [[ -z "$BINARY" ]]; then
    echo "lspmux-wrap: error: binary name required as first argument" >&2
    exit 1
fi
shift  # remaining args are passed through to the binary

# Strip this bin directory from PATH to avoid finding our own wrapper again.
THIS_DIR="$(cd "$(dirname "$0")" && pwd)"
PATH="$(printf '%s' "$PATH" | tr ':' '\n' | grep -v "^${THIS_DIR}$" | tr '\n' ':' | sed 's/:$//')"
export PATH

# Locate the real binary on the (now-stripped) PATH.
REAL_BIN="$(command -v "$BINARY" 2>/dev/null || true)"
if [[ -z "$REAL_BIN" ]]; then
    echo "lspmux-wrap: error: '$BINARY' not found on PATH" >&2
    exit 1
fi

# Forward through lspmux. Fail fast if lspmux is missing or server is down.
if ! command -v lspmux &>/dev/null; then
    echo "lspmux-wrap: error: lspmux not installed. Run: cargo install lspmux" >&2
    exit 1
fi

# Log wrapper invocation for debugging (rotate at 100KB)
LSPMUX_LOG="${LSPMUX_LOG:-$HOME/Library/Logs/lspmux/wrap.log}"
mkdir -p "$(dirname "$LSPMUX_LOG")" 2>/dev/null || true
if [[ -f "$LSPMUX_LOG" ]] && [[ "$(wc -c < "$LSPMUX_LOG")" -gt 102400 ]]; then
    mv "$LSPMUX_LOG" "${LSPMUX_LOG}.1"
fi
echo "$(date -Iseconds) pid=$$ binary=$BINARY real=$REAL_BIN" >> "$LSPMUX_LOG" 2>/dev/null || true

exec lspmux client --server-path "$REAL_BIN" -- "$@"
