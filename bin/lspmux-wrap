#!/bin/bash
# lspmux-wrap — LSP binary interceptor
#
# Usage: lspmux-wrap <binary-name> [args...]
#
# Called by shadow wrappers (pyright-langserver, gopls, etc.).
# Finds the real LSP binary and forwards through lspmux client.
# Fails loudly if lspmux is not installed or the server is down.
#
# Strips all directories containing lspmux-wrap from PATH to prevent
# infinite recursion when the script is symlinked across multiple locations.

set -euo pipefail

BINARY="${1:-}"
if [[ -z "$BINARY" ]]; then
    echo "lspmux-wrap: error: binary name required as first argument" >&2
    exit 1
fi
shift  # remaining args are passed through to the binary

# Strip any directory containing lspmux-wrap from PATH to avoid finding our
# own wrapper again. Simple THIS_DIR stripping fails when the script is
# symlinked (e.g., ~/Dev/dotfiles/bin → conductor workspace copy) because
# both paths are on PATH but only one gets stripped.
CLEAN_PATH=""
while IFS= read -r dir; do
    [[ -z "$dir" ]] && continue
    [[ -f "$dir/lspmux-wrap" ]] && continue
    CLEAN_PATH="${CLEAN_PATH:+$CLEAN_PATH:}$dir"
done <<< "$(printf '%s' "$PATH" | tr ':' '\n')"
PATH="$CLEAN_PATH"
export PATH

# Locate the real binary on the (now-stripped) PATH.
# Falls back to rustup for Rust toolchain binaries (rust-analyzer, rustfmt, etc.)
# since brew-installed rustup doesn't always create ~/.cargo/bin proxies.
REAL_BIN="$(command -v "$BINARY" 2>/dev/null || true)"
# Reject if the found binary is another lspmux-wrap shadow wrapper (symlink loop)
if [[ -n "$REAL_BIN" ]] && [[ -f "$(dirname "$REAL_BIN")/lspmux-wrap" ]]; then
    REAL_BIN=""
fi
if [[ -z "$REAL_BIN" ]] && command -v rustup &>/dev/null; then
    REAL_BIN="$(rustup which "$BINARY" 2>/dev/null || true)"
fi
if [[ -z "$REAL_BIN" ]]; then
    echo "lspmux-wrap: error: '$BINARY' not found on PATH or via rustup" >&2
    exit 1
fi

# Forward through lspmux. Fail fast if lspmux is missing or server is down.
if ! command -v lspmux &>/dev/null; then
    echo "lspmux-wrap: error: lspmux not installed. Run: cargo install lspmux" >&2
    exit 1
fi

# Log wrapper invocation for debugging (rotate at 100KB)
LSPMUX_LOG="${LSPMUX_LOG:-$HOME/Library/Logs/lspmux/wrap.log}"
mkdir -p "$(dirname "$LSPMUX_LOG")" 2>/dev/null || true
if [[ -f "$LSPMUX_LOG" ]] && [[ "$(wc -c < "$LSPMUX_LOG")" -gt 102400 ]]; then
    mv "$LSPMUX_LOG" "${LSPMUX_LOG}.1"
fi
echo "$(date -Iseconds) pid=$$ binary=$BINARY real=$REAL_BIN" >> "$LSPMUX_LOG" 2>/dev/null || true

exec lspmux client --server-path "$REAL_BIN" -- "$@"
