#!/usr/bin/env bash
# ccw-sweep — scan ~/Dev repos for stale worktrees and safely clean them up
#
# Usage:
#   ccw-sweep              Interactive sweep with safety checks
#   ccw-sweep --dry-run    Preview what would be cleaned (no changes)
#   ccw-sweep --auto       Auto-remove safe worktrees (merged + clean), prompt for others
#   ccw-sweep --path DIR   Scan a specific directory instead of ~/Dev

set -euo pipefail

# ── Colors ──────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
DIM='\033[2m'
BOLD='\033[1m'
RESET='\033[0m'

# ── Defaults ────────────────────────────────────────────────────────
SCAN_ROOT="${HOME}/Dev"
DRY_RUN=false
AUTO_CLEAN=false

# ── Parse args ──────────────────────────────────────────────────────
while [[ $# -gt 0 ]]; do
    case "$1" in
        --dry-run) DRY_RUN=true; shift ;;
        --auto)    AUTO_CLEAN=true; shift ;;
        --path)    SCAN_ROOT="$2"; shift 2 ;;
        -h|--help)
            echo "Usage: ccw-sweep [--dry-run] [--auto] [--path DIR]"
            echo ""
            echo "Scans for stale git worktrees and safely removes them."
            echo ""
            echo "Options:"
            echo "  --dry-run   Preview what would be cleaned (no changes)"
            echo "  --auto      Auto-remove safe worktrees, prompt for others"
            echo "  --path DIR  Scan DIR instead of ~/Dev"
            exit 0 ;;
        *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
done

if [[ ! -d "$SCAN_ROOT" ]]; then
    echo -e "${RED}Directory not found: ${SCAN_ROOT}${RESET}" >&2
    exit 1
fi

# ── Counters ────────────────────────────────────────────────────────
TOTAL=0
SAFE=0
REMOVED=0
SKIPPED=0

# ── Helpers ─────────────────────────────────────────────────────────

check_worktree() {
    local wt_path="$1"
    local repo_root="$2"
    local slug
    slug="$(basename "$wt_path")"
    local branch="claude/${slug}"

    local status="SAFE"
    local reasons=()

    # Does the worktree directory exist and have a .git?
    if [[ ! -e "${wt_path}/.git" ]]; then
        echo -e "  ${DIM}${slug}: not a valid worktree, skipping${RESET}"
        return 1
    fi

    # Check for uncommitted changes (staged or unstaged)
    if ! git -C "$wt_path" diff --quiet HEAD 2>/dev/null; then
        status="DIRTY"
        reasons+=("uncommitted changes")
    fi

    # Check for staged but uncommitted
    if ! git -C "$wt_path" diff --cached --quiet 2>/dev/null; then
        status="DIRTY"
        reasons+=("staged changes")
    fi

    # Check for untracked files
    local untracked
    untracked="$(git -C "$wt_path" ls-files --others --exclude-standard 2>/dev/null)"
    if [[ -n "$untracked" ]]; then
        local count
        count="$(echo "$untracked" | wc -l | tr -d ' ')"
        if [[ "$status" != "DIRTY" ]]; then
            status="WARN"
        fi
        reasons+=("${count} untracked file(s)")
    fi

    # Check if branch ref exists
    local branch_exists=true
    if ! git -C "$repo_root" rev-parse --verify "$branch" &>/dev/null; then
        branch_exists=false
        reasons+=("branch not found")
    fi

    # Determine merge status — always check the worktree's actual content
    local is_merged=false

    # Step 1: git branch --merged (only if branch ref exists)
    if $branch_exists; then
        local merged
        merged="$(git -C "$repo_root" branch --merged main 2>/dev/null | sed 's/^[ *]*//')"
        if echo "$merged" | grep -qx "$branch"; then
            is_merged=true
            reasons+=("merged into main")
        fi
    fi

    # Step 2: squash-merged PR check (only if branch ref exists)
    if ! $is_merged && $branch_exists && command -v gh &>/dev/null; then
        local pr_state
        pr_state="$(gh pr list --repo "$(git -C "$repo_root" remote get-url origin 2>/dev/null)" \
            --head "$branch" --state all --json state --jq '.[0].state' 2>/dev/null || true)"
        if [[ "$pr_state" == "MERGED" ]]; then
            is_merged=true
            reasons+=("PR squash-merged")
        elif [[ "$pr_state" == "CLOSED" ]]; then
            reasons+=("PR closed without merge")
        fi
    fi

    # Step 3: diff worktree HEAD against main (works even if branch ref is gone)
    # This is the ground truth — empty diff means all content is in main
    if ! $is_merged; then
        local diff_stat
        diff_stat="$(git -C "$wt_path" diff --stat main...HEAD -- 2>/dev/null)"
        if [[ -z "$diff_stat" ]]; then
            is_merged=true
            reasons+=("diff vs main is empty")
        fi
    fi

    if ! $is_merged; then
        if [[ "$status" == "SAFE" ]]; then
            status="WARN"
        fi
        reasons+=("NOT merged into main")
    fi

    # Check for unpushed commits (only if branch ref exists)
    if $branch_exists; then
        local upstream
        upstream="$(git -C "$wt_path" rev-parse --abbrev-ref '@{upstream}' 2>/dev/null || true)"
        if [[ -n "$upstream" ]]; then
            local ahead
            ahead="$(git -C "$wt_path" rev-list --count '@{upstream}..HEAD' 2>/dev/null || echo 0)"
            if (( ahead > 0 )); then
                if [[ "$status" == "SAFE" ]]; then
                    status="WARN"
                fi
                reasons+=("${ahead} unpushed commit(s)")
            fi
        else
            # No upstream — check if there are commits beyond main
            if ! $is_merged; then
                local ahead_main
                ahead_main="$(git -C "$wt_path" rev-list --count 'main..HEAD' 2>/dev/null || echo 0)"
                if (( ahead_main > 0 )); then
                    if [[ "$status" == "SAFE" ]]; then
                        status="WARN"
                    fi
                    reasons+=("${ahead_main} commit(s) ahead of main, no upstream")
                fi
            fi
        fi
    fi

    # Check age (last commit date)
    local last_commit_relative
    last_commit_relative="$(git -C "$wt_path" log -1 --format='%cr' 2>/dev/null || echo 'unknown')"

    # ── Display ─────────────────────────────────────────────────────
    local color
    case "$status" in
        SAFE)  color="$GREEN" ;;
        WARN)  color="$YELLOW" ;;
        DIRTY) color="$RED" ;;
    esac

    local reason_str
    reason_str="$(IFS=', '; echo "${reasons[*]}")"

    echo -e "  ${color}[${status}]${RESET} ${BOLD}${slug}${RESET} ${DIM}(${last_commit_relative})${RESET}"
    echo -e "         ${reason_str}"

    TOTAL=$((TOTAL + 1))

    # ── Action ──────────────────────────────────────────────────────
    if $DRY_RUN; then
        if [[ "$status" == "SAFE" ]]; then
            SAFE=$((SAFE + 1))
        fi
        return 0
    fi

    local should_remove=false

    if [[ "$status" == "SAFE" ]]; then
        SAFE=$((SAFE + 1))
        if $AUTO_CLEAN; then
            should_remove=true
        else
            read -rp "         Remove? [y/N] " answer </dev/tty
            [[ "$answer" =~ ^[Yy] ]] && should_remove=true
        fi
    elif [[ "$status" == "WARN" ]]; then
        read -rp "         Remove anyway? [y/N] " answer </dev/tty
        [[ "$answer" =~ ^[Yy] ]] && should_remove=true
    else
        read -rp "         Has uncommitted work. Remove? [y/N] " answer </dev/tty
        [[ "$answer" =~ ^[Yy] ]] && should_remove=true
    fi

    if $should_remove; then
        remove_worktree "$wt_path" "$repo_root" "$branch"
        REMOVED=$((REMOVED + 1))
    else
        SKIPPED=$((SKIPPED + 1))
    fi
}

remove_worktree() {
    local wt_path="$1"
    local repo_root="$2"
    local branch="$3"
    local slug
    slug="$(basename "$wt_path")"

    # Remove the worktree
    git -C "$repo_root" worktree remove --force "$wt_path" 2>/dev/null \
        || rm -rf "$wt_path"

    # Delete the branch if it exists
    if git -C "$repo_root" rev-parse --verify "$branch" &>/dev/null; then
        git -C "$repo_root" branch -D "$branch" 2>/dev/null || true
    fi

    # Clean Claude project symlink
    local claude_projects="${HOME}/.claude/projects"
    local wt_key="${wt_path//[\/.]/-}"
    if [[ -L "${claude_projects}/${wt_key}" ]]; then
        rm "${claude_projects}/${wt_key}"
    fi

    # Clean Serena project config
    if command -v yq &>/dev/null && [[ -f "${HOME}/.serena/serena_config.yml" ]]; then
        yq -i "del(.projects[] | select(. == \"${wt_path}\"))" \
            "${HOME}/.serena/serena_config.yml" 2>/dev/null || true
    fi

    echo -e "         ${GREEN}Removed${RESET}"
}

# ── Main ────────────────────────────────────────────────────────────

if $DRY_RUN; then
    echo -e "${CYAN}DRY RUN — no changes will be made${RESET}"
    echo ""
fi

echo -e "${BOLD}Scanning ${SCAN_ROOT} for worktrees...${RESET}"
echo ""

FOUND_REPOS=0

# Find all .worktrees directories (max depth 3 to avoid deep traversal)
while IFS= read -r -u3 wt_root; do
    repo_root="$(dirname "$wt_root")"
    repo_name="${repo_root#"${SCAN_ROOT}/"}"

    # Verify this is actually a git repo
    if ! git -C "$repo_root" rev-parse --is-inside-work-tree &>/dev/null; then
        continue
    fi

    # Fetch latest to ensure merge status is accurate
    git -C "$repo_root" fetch --quiet 2>/dev/null || true

    # Collect worktrees in this repo
    local_wts=()
    for entry in "${wt_root}"/*/; do
        [[ -d "$entry" ]] && local_wts+=("${entry%/}")
    done
    if (( ${#local_wts[@]} == 0 )); then
        continue
    fi

    FOUND_REPOS=$((FOUND_REPOS + 1))
    echo -e "${CYAN}${repo_name}${RESET} ${DIM}(${#local_wts[@]} worktree(s))${RESET}"

    for wt_path in "${local_wts[@]}"; do
        check_worktree "$wt_path" "$repo_root" || true
    done
    echo ""

done 3< <(find "$SCAN_ROOT" -maxdepth 3 -type d -name '.worktrees' 2>/dev/null)

# ── Summary ─────────────────────────────────────────────────────────

if (( FOUND_REPOS == 0 )); then
    echo -e "${GREEN}No worktrees found under ${SCAN_ROOT}${RESET}"
    exit 0
fi

echo -e "${BOLD}Summary:${RESET}"
echo -e "  Total:   ${TOTAL}"
echo -e "  Safe:    ${GREEN}${SAFE}${RESET}"
if ! $DRY_RUN; then
    echo -e "  Removed: ${GREEN}${REMOVED}${RESET}"
    echo -e "  Skipped: ${YELLOW}${SKIPPED}${RESET}"
fi

# Prune any worktree refs that point to missing directories
if ! $DRY_RUN && (( REMOVED > 0 )); then
    echo ""
    echo -e "${DIM}Running git worktree prune...${RESET}"
    while IFS= read -r -u3 wt_root; do
        repo_root="$(dirname "$wt_root")"
        git -C "$repo_root" worktree prune 2>/dev/null || true
    done 3< <(find "$SCAN_ROOT" -maxdepth 3 -type d -name '.worktrees' 2>/dev/null)
fi
