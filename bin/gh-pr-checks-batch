#!/usr/bin/env bash
# Batch CI checks for multiple PRs (no MCP equivalent for checks)
# Usage: gh-pr-checks-batch <PR#> [PR# ...]
set -euo pipefail

if [[ $# -eq 0 ]]; then
    echo "Usage: gh-pr-checks-batch <PR#> [PR# ...]"
    exit 1
fi

for pr in "$@"; do
    echo "=== PR #$pr CHECKS ==="
    gh pr checks "$pr" 2>/dev/null || echo "(no checks)"
done
