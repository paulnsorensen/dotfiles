#!/usr/bin/env bash
# claude-json-prune — remove stale project entries from ~/.claude.json
#
# Usage:
#   claude-json-prune              Preview stale entries (dry run)
#   claude-json-prune --apply      Remove stale entries (creates backup first)

set -euo pipefail

CLAUDE_JSON="${CLAUDE_JSON:-$HOME/.claude.json}"
BACKUP_DIR="${BACKUP_DIR:-$HOME/.local/state/dotfiles/backups}"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
DIM='\033[2m'
BOLD='\033[1m'
RESET='\033[0m'

if [[ ! -f "$CLAUDE_JSON" ]]; then
  echo -e "${RED}No ~/.claude.json found${RESET}" >&2
  exit 1
fi

if ! command -v jq &>/dev/null; then
  echo -e "${RED}jq is required but not installed${RESET}" >&2
  exit 1
fi

apply=false
[[ "${1:-}" == "--apply" ]] && apply=true

# Find stale project paths (directory no longer exists on disk)
stale_paths=()
while IFS= read -r path; do
  [[ ! -d "$path" ]] && stale_paths+=("$path")
done < <(jq -r '.projects | keys[]' "$CLAUDE_JSON")

total=$(jq '.projects | keys | length' "$CLAUDE_JSON")
stale=${#stale_paths[@]}
lines=$(wc -l < "$CLAUDE_JSON")

echo -e "${BOLD}~/.claude.json${RESET}"
echo -e "  Projects: ${total}  Lines: ${lines}"
echo ""

if [[ "$stale" -eq 0 ]]; then
  echo -e "${GREEN}No stale entries found. Already clean.${RESET}"
  exit 0
fi

echo -e "${YELLOW}${stale} stale entries${RESET} (path no longer exists):"
echo ""
for p in "${stale_paths[@]}"; do
  echo -e "  ${DIM}${p/#$HOME/\~}${RESET}"
done
echo ""

if ! $apply; then
  echo -e "Run ${BOLD}claude-json-prune --apply${RESET} to remove them."
  exit 0
fi

# Build jq filter to delete all stale paths
filter='.'
for p in "${stale_paths[@]}"; do
  filter="$filter | del(.projects[\"$p\"])"
done

# Backup
mkdir -p "$BACKUP_DIR"
backup_file="$BACKUP_DIR/claude.json.$(date +%Y%m%d-%H%M%S)"
cp "$CLAUDE_JSON" "$backup_file"

# Apply
tmpfile=$(mktemp)
jq "$filter" "$CLAUDE_JSON" > "$tmpfile"
mv "$tmpfile" "$CLAUDE_JSON"

new_total=$(jq '.projects | keys | length' "$CLAUDE_JSON")
new_lines=$(wc -l < "$CLAUDE_JSON")

echo -e "${GREEN}Pruned ${stale} stale entries${RESET}"
echo -e "  Before: ${total} projects, ${lines} lines"
echo -e "  After:  ${new_total} projects, ${new_lines} lines"
echo -e "  Backup: ${DIM}${backup_file/#$HOME/\~}${RESET}"
