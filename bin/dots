#!/usr/bin/env bash
# Dotfiles management command
# Usage: dot [command] [args]

set -euo pipefail

# Allow override for testing, default to production path
DOTFILES_DIR="${DOTFILES_DIR:-${HOME}/Dev/dotfiles}"
DOTFILES_STATE_DIR="${DOTFILES_STATE_DIR:-${HOME}/.local/state/dotfiles}"

# Load .env so downstream sync steps (chezmoi apply, the base-profile
# render via `ap`, etc.) get API keys regardless of how `dots` was invoked.
# `ap` resolves ${VAR} MCP env refs at render time from .env. zsh/core.zsh only
# fires for interactive zsh — running `dots sync` from bash, a script, or a
# non-interactive shell would otherwise leave CONTEXT7_API_KEY / TAVILY_API_KEY
# unset and abort `chezmoi apply` at the copilot template, skipping every
# template that sorts after it (including ~/.gitconfig).
if [[ -f "$DOTFILES_DIR/.env" ]]; then
    set -a
    # shellcheck disable=SC1091
    source "$DOTFILES_DIR/.env"
    set +a
fi

# Colors
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
NC='\033[0m'

# Strip leaked SSL_CERT_FILE / SSL_CERT_DIR pointing at non-existent paths.
# Comes up when SSHing in from a Mac with env forwarding (or running under a
# wrapper that hardcodes the BSD cert path /etc/ssl/cert.pem). Curl honors
# the var and refuses TLS handshakes with "error adding trust anchors",
# which breaks every bootstrap (yq, chezmoi, uv, …) until unset.
for _ssl_var in SSL_CERT_FILE SSL_CERT_DIR; do
    _val="${!_ssl_var:-}"
    if [[ -n "$_val" && ! -e "$_val" ]]; then
        echo -e "${YELLOW}⚠️  Unsetting $_ssl_var=$_val (path does not exist on this host)${NC}" >&2
        unset "$_ssl_var"
    fi
done
unset _ssl_var _val

# Ensure we're in the dotfiles directory for git commands
cd_dotfiles() {
    cd "$DOTFILES_DIR" || {
        echo -e "${RED}Error: Cannot access dotfiles directory at $DOTFILES_DIR${NC}" >&2
        exit 1
    }
}

# Show help
show_help() {
    echo -e "$(cat << EOF
${CYAN}╔════════════════════════════════════════╗${NC}
${CYAN}║       Dotfiles Management Tool         ║${NC}
${CYAN}╚════════════════════════════════════════╝${NC}

${GREEN}Usage:${NC} dots [command] [args]

${BLUE}Commands:${NC}
  ${GREEN}update${NC}          Pull latest changes and run sync
  ${GREEN}sync${NC}            Run the sync script
  ${GREEN}upgrade${NC}         Upgrade installed packages and refresh remote skills
  ${GREEN}status${NC}          Show git status of dotfiles
  ${GREEN}rollback${NC}        Show how to undo a sync (git revert + dots sync)
  ${GREEN}doctor${NC}          Run health checks and profile shell
  ${GREEN}profile${NC}         Manage harness-agnostic agent profiles (run 'dots profile help')
  ${GREEN}test${NC}            Run test suite
  ${GREEN}help${NC}            Show this help message

${BLUE}Quick Actions:${NC}
  ${GREEN}dots${NC}            Show status (same as 'dots status')
  ${GREEN}dots u${NC}          Update (shorthand)
  ${GREEN}dots s${NC}          Sync (shorthand)
  ${GREEN}dots s refresh${NC}  Force re-check all packages (bypass cache)
  ${GREEN}dots up${NC}         Upgrade packages (shorthand)
  ${GREEN}dots t${NC}          Test (shorthand)

${BLUE}Examples:${NC}
  dots update      # Pull changes and sync
  dots rollback    # Show the git revert undo path
  dots doctor      # Health checks + shell performance
  dots test        # Run test suite

EOF
)"
}

# Update dotfiles
do_update() {
    echo -e "${BLUE}📦 Updating dotfiles...${NC}"
    cd_dotfiles

    # Fetch changes
    git fetch || {
        echo -e "${RED}Failed to fetch updates${NC}" >&2
        exit 1
    }

    # Check if we're behind (skip cleanly if no upstream is configured)
    if ! git rev-parse --abbrev-ref '@{u}' >/dev/null 2>&1; then
        echo -e "${YELLOW}⚠️  No upstream configured for current branch, skipping update${NC}"
        return 0
    fi

    LOCAL=$(git rev-parse HEAD)
    REMOTE=$(git rev-parse '@{u}')
    BASE=$(git merge-base HEAD '@{u}')

    if [[ "$LOCAL" == "$REMOTE" ]]; then
        echo -e "${GREEN}✅ Already up to date!${NC}"
    elif [[ "$LOCAL" == "$BASE" ]]; then
        # Pull changes
        echo -e "${BLUE}Pulling changes...${NC}"
        git pull --rebase

        echo -e "${GREEN}✅ Updated successfully!${NC}"
        echo
        echo -e "${BLUE}Running sync...${NC}"
        # Gate fallback on existence, not exit code — otherwise a real
        # mid-sync failure silently falls through to a different script.
        if [[ -f "$DOTFILES_DIR/.sync-with-rollback" ]]; then
            "$DOTFILES_DIR/.sync-with-rollback"
        else
            "$DOTFILES_DIR/.sync"
        fi
    else
        echo -e "${YELLOW}⚠️  Local changes detected${NC}" >&2
        echo "Please commit or stash your changes first" >&2
        git status -s
        exit 1
    fi
}

# Sync dotfiles
do_sync() {
    echo -e "${BLUE}🔄 Syncing dotfiles...${NC}"
    cd_dotfiles

    "$DOTFILES_DIR/.sync-with-rollback" "$@"
}

# Show status
do_status() {
    cd_dotfiles

    # Check for updates first
    git fetch --quiet 2>/dev/null || true

    LOCAL=$(git rev-parse HEAD 2>/dev/null || echo "unknown")
    REMOTE=$(git rev-parse '@{u}' 2>/dev/null || echo "unknown")

    echo -e "${CYAN}╔════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║          Dotfiles Status               ║${NC}"
    echo -e "${CYAN}╚════════════════════════════════════════╝${NC}"
    echo

    # Branch info
    BRANCH=$(git branch --show-current 2>/dev/null || echo "unknown")
    echo -e "${BLUE}Branch:${NC} $BRANCH"

    # Check if up to date
    if [[ "$LOCAL" != "unknown" ]] && [[ "$REMOTE" != "unknown" ]]; then
        if [[ "$LOCAL" == "$REMOTE" ]]; then
            echo -e "${GREEN}Status: ✅ Up to date${NC}"
        else
            BASE=$(git merge-base HEAD '@{u}' 2>/dev/null || echo "unknown")
            if [[ "$LOCAL" == "$BASE" ]]; then
                BEHIND=$(git rev-list --count 'HEAD..@{u}')
                echo -e "${YELLOW}Status: 📦 $BEHIND commit(s) behind${NC}"
            elif [[ "$REMOTE" == "$BASE" ]]; then
                AHEAD=$(git rev-list --count '@{u}..HEAD')
                echo -e "${BLUE}Status: 📤 $AHEAD commit(s) ahead${NC}"
            else
                echo -e "${YELLOW}Status: ⚠️  Diverged${NC}"
            fi
        fi
    fi

    echo

    # Git status
    if [[ -n "$(git status -s 2>/dev/null)" ]]; then
        echo -e "${YELLOW}Uncommitted changes:${NC}"
        git status -s
    else
        echo -e "${GREEN}Working directory clean${NC}"
    fi

    # Last sync info
    if [[ -f "$DOTFILES_STATE_DIR/last_sync" ]]; then
        LAST_SYNC=$(cat "$DOTFILES_STATE_DIR/last_sync")
        if [[ "$(uname)" == "Darwin" ]]; then
            LAST_SYNC_DATE=$(date -r "$LAST_SYNC" "+%Y-%m-%d %H:%M:%S" 2>/dev/null || echo "unknown")
        else
            LAST_SYNC_DATE=$(date -d "@$LAST_SYNC" "+%Y-%m-%d %H:%M:%S" 2>/dev/null || echo "unknown")
        fi
        echo
        echo -e "${BLUE}Last sync:${NC} $LAST_SYNC_DATE"
    fi
}

# Run health checks
do_doctor() {
    echo -e "${CYAN}╔════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║         Dotfiles Health Check          ║${NC}"
    echo -e "${CYAN}╚════════════════════════════════════════╝${NC}"
    echo

    local issues=0

    # Check for broken symlinks
    echo -e "${BLUE}Checking symlinks...${NC}"
    local broken_links=0
    while IFS= read -r link; do
        if [[ ! -e "$link" ]]; then
            echo -e "  ${RED}✗ Broken: $link${NC}"
            broken_links=$((broken_links + 1))
            issues=$((issues + 1))
        fi
    done < <(find "$HOME" -maxdepth 2 -type l 2>/dev/null)

    if [[ $broken_links -eq 0 ]]; then
        echo -e "  ${GREEN}✓ All symlinks valid${NC}"
    fi

    # Check pre-commit hooks (prek)
    echo -e "${BLUE}Checking pre-commit hooks...${NC}"
    if [[ -f .git/hooks/pre-commit ]] && grep -q prek .git/hooks/pre-commit 2>/dev/null; then
        echo -e "  ${GREEN}✓ prek hooks installed${NC}"
    elif command -v prek &>/dev/null; then
        echo -e "  ${YELLOW}⚠ prek hooks not installed${NC}"
        echo -e "    Run: ${GREEN}prek install${NC}"
        issues=$((issues + 1))
    else
        echo -e "  ${RED}✗ prek not found${NC}"
        echo -e "    Run: ${GREEN}brew install prek${NC}"
        issues=$((issues + 1))
    fi

    # Check for required commands
    echo -e "${BLUE}Checking dependencies...${NC}"
    local missing_deps=()
    for cmd in git zsh curl; do
        if ! command -v "$cmd" &>/dev/null; then
            missing_deps+=("$cmd")
            issues=$((issues + 1))
        fi
    done

    if [[ ${#missing_deps[@]} -eq 0 ]]; then
        echo -e "  ${GREEN}✓ All required commands found${NC}"
    else
        echo -e "  ${RED}✗ Missing: ${missing_deps[*]}${NC}"
    fi

    # Check chezmoi health (deps, paths, encryption backends)
    echo -e "${BLUE}Checking chezmoi...${NC}"
    if command -v chezmoi &>/dev/null; then
        chezmoi --source "$DOTFILES_DIR/chezmoi" doctor 2>&1 | sed 's/^/  /'
        if [[ ${PIPESTATUS[0]} -ne 0 ]]; then
            issues=$((issues + 1))
        fi
    else
        echo -e "  ${YELLOW}⚠ chezmoi not installed${NC}"
        echo -e "    Run: ${GREEN}dots sync${NC}"
        issues=$((issues + 1))
    fi

    # Check VS Code settings if they exist
    if [[ -d "$DOTFILES_DIR/vscode" ]]; then
        echo -e "${BLUE}Checking VS Code configuration...${NC}"
        if [[ -L "$HOME/Library/Application Support/Code/User/settings.json" ]]; then
            echo -e "  ${GREEN}✓ VS Code settings symlinked${NC}"
        else
            echo -e "  ${YELLOW}⚠ VS Code settings not symlinked${NC}"
            echo -e "    Run: ${GREEN}cd $DOTFILES_DIR/vscode && ./.sync${NC}"
        fi
    fi

    # Profile shell startup
    echo -e "${BLUE}Profiling shell startup...${NC}"
    local times=()
    for _ in {1..3}; do
        local start
        start=$(date +%s%N 2>/dev/null || date +%s000000000)
        zsh -i -c exit 2>/dev/null || true
        local end
        end=$(date +%s%N 2>/dev/null || date +%s000000000)
        local duration=$(( (end - start) / 1000000 ))
        times+=("$duration")
    done

    # Calculate average
    local sum=0
    for time in "${times[@]}"; do
        sum=$((sum + time))
    done
    local avg=$((sum / 3))

    if [[ $avg -lt 200 ]]; then
        echo -e "  ${GREEN}✓ Shell startup: ${avg}ms (fast)${NC}"
    elif [[ $avg -lt 500 ]]; then
        echo -e "  ${YELLOW}⚠ Shell startup: ${avg}ms (moderate)${NC}"
    else
        echo -e "  ${RED}✗ Shell startup: ${avg}ms (slow)${NC}"
        echo -e "    Run ${GREEN}DOTFILES_PROFILE=1 zsh${NC} for detailed profiling"
        issues=$((issues + 1))
    fi

    # Check local LLM stack (only when the localLLM flag deployed the healthcheck)
    if [[ -x "$HOME/local-llm/scripts/healthcheck.sh" ]]; then
        echo -e "${BLUE}Checking local LLM stack...${NC}"
        if "$HOME/local-llm/scripts/healthcheck.sh" --quiet; then
            : # healthcheck prints its own per-line ✓/✗
        else
            issues=$((issues + 1))
        fi
    fi

    # Summary
    echo
    if [[ $issues -eq 0 ]]; then
        echo -e "${GREEN}═══ All checks passed! ═══${NC}"
    else
        echo -e "${YELLOW}═══ Found $issues issue(s) ═══${NC}"
    fi
}

# Main command handler
case "${1:-status}" in
    update|u)
        do_update
        ;;
    sync|s)
        shift
        do_sync "$@"
        ;;
    upgrade|up)
        echo -e "${BLUE}⬆️  Upgrading packages...${NC}"
        cd_dotfiles
        UPGRADE_MODE=true bash "$DOTFILES_DIR/packages/sync.sh"

        echo
        echo -e "${BLUE}⬆️  Refreshing remote skills...${NC}"
        # `npx skills add --force` re-clones each source at its latest default
        # branch (float-to-latest), so always run it — the install does its own
        # work; there's no cheap upstream-up-to-date probe to short-circuit on.
        if ! bash "$DOTFILES_DIR/chezmoi/lib/install-external.sh" \
                "$DOTFILES_DIR/skills/_registry.yaml" --force; then
            echo -e "${YELLOW}⚠️  Remote skills refresh failed (continuing)${NC}" >&2
        fi
        ;;
    status|st)
        do_status
        ;;
    rollback|rb)
        echo -e "${BLUE}Rollback is now git-backed.${NC} The custom backup/restore layer was retired —"
        echo "chezmoi's git-tracked source tree is the undo story. To revert a sync:"
        echo
        echo -e "  ${GREEN}cd $DOTFILES_DIR${NC}"
        echo -e "  ${GREEN}git revert <commit>${NC}   # or: git checkout <ref> -- <path>"
        echo -e "  ${GREEN}dots sync${NC}              # re-apply the reverted state"
        ;;
    doctor|d)
        do_doctor
        ;;
    profile|p)
        shift
        "$DOTFILES_DIR/agent-profile/ap" "$@"
        ;;
    test|t)
        shift
        if [[ -f "$DOTFILES_DIR/tests/run-tests.sh" ]]; then
            "$DOTFILES_DIR/tests/run-tests.sh" "$@"
        else
            echo -e "${RED}Test suite not found${NC}" >&2
            echo "Tests are located in: $DOTFILES_DIR/tests/" >&2
            exit 1
        fi
        ;;
    help|h|--help|-h)
        show_help
        ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}" >&2
        echo >&2
        show_help >&2
        exit 1
        ;;
esac
