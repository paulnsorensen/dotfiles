#!/bin/bash
############################
# .sync-with-rollback
# Enhanced sync script with rollback capability and state management
############################

set -euo pipefail  # Fail fast on errors

########## Variables

dir=$(pwd)
olddir=~/.dotfiles.bak             # old dotfiles backup directory

# State management
DOTFILES_STATE_DIR="${HOME}/.local/state/dotfiles"
BACKUP_DIR="${DOTFILES_STATE_DIR}/backups/$(date +%Y%m%d_%H%M%S)"
MANIFEST_FILE="${DOTFILES_STATE_DIR}/current.manifest"
ROLLBACK_LOG="${DOTFILES_STATE_DIR}/rollback.log"

# Source helpers from the script's own directory. Test harnesses that eval
# this file may override the location via SYNC_SCRIPT.
_sync_script_path="${SYNC_SCRIPT:-${BASH_SOURCE[0]:-}}"
if [[ -n "$_sync_script_path" ]]; then
    _sync_script_dir="$(cd "${_sync_script_path%/*}" && pwd)"
    # shellcheck source=.sync-lib.sh
    [[ -f "$_sync_script_dir/.sync-lib.sh" ]] && source "$_sync_script_dir/.sync-lib.sh"
    unset _sync_script_dir
fi
unset _sync_script_path

########## Functions

# Initialize state directory
init_state() {
    log_info "Initializing state management..."
    mkdir -p "${DOTFILES_STATE_DIR}/backups"
    mkdir -p "${BACKUP_DIR}"

    # Save current timestamp
    date +%s > "${DOTFILES_STATE_DIR}/last_sync"
}

# Create manifest of current symlinks
create_manifest() {
    log_info "Creating manifest of current state..."
    true > "${MANIFEST_FILE}.tmp"

    # Find all symlinks pointing to our dotfiles (exclude protected directories)
    (find "${HOME}" -maxdepth 3 -type l \
        -not -path "${HOME}/Library/Mobile Documents*" \
        -not -path "${HOME}/Library/Application Support/MobileSync*" \
        -not -path "${HOME}/Music*" \
        -not -path "${HOME}/Pictures/Photos*" \
        2>/dev/null || true) | while read -r link; do
        target=$(readlink "${link}" 2>/dev/null || true)
        if [[ "${target}" == "${dir}"* ]]; then
            echo "${link}:${target}" >> "${MANIFEST_FILE}.tmp"
        fi
    done

    # If manifest exists, back it up
    if [[ -f "${MANIFEST_FILE}" ]]; then
        cp "${MANIFEST_FILE}" "${BACKUP_DIR}/manifest.backup"
    fi

    mv "${MANIFEST_FILE}.tmp" "${MANIFEST_FILE}"
    log_success "Manifest created with $(wc -l < "${MANIFEST_FILE}") symlinks"
}

# Directories managed by .sync scripts — their config is symlinked,
# the rest is runtime data that shouldn't be backed up. This is layered on
# top of SYNC_SKIP_LIST (from .sync-lib.sh): anything in either list is
# excluded from the backup loop.
BACKUP_EXCLUDE=("claude")

# Backup current dotfiles before making changes
backup_current_state() {
    log_info "Backing up current dotfiles to ${BACKUP_DIR}..."

    # Copy manifest
    if [[ -f "${MANIFEST_FILE}" ]]; then
        cp "${MANIFEST_FILE}" "${BACKUP_DIR}/manifest"
    fi

    # Backup existing dotfiles
    for file in *; do
        # Skip directories that are never symlinked (.git, .local, agents/, …) —
        # otherwise the backup loop touches every top-level dir, including the
        # ones documented as out-of-scope in SYNC_SKIP_LIST.
        is_skipped "$file" && continue
        # Skip directories managed by .sync scripts (runtime data, not config)
        if printf '%s\n' "${BACKUP_EXCLUDE[@]}" | grep -qx "$file"; then
            continue
        fi
        if [[ -f ~/."$file" || -d ~/."$file" ]]; then
            if [[ ! -L ~/."$file" ]]; then
                log_info "Backing up .$file"
                cp -r ~/."$file" "${BACKUP_DIR}/" 2>/dev/null || true
            fi
        fi
    done

    # Save metadata
    cat > "${BACKUP_DIR}/metadata.json" <<EOF
{
    "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
    "directory": "${dir}",
    "git_commit": "$(git rev-parse HEAD 2>/dev/null || echo 'unknown')",
    "git_branch": "$(git branch --show-current 2>/dev/null || echo 'unknown')"
}
EOF

    log_success "Backup completed at ${BACKUP_DIR}"
}

# List available backups
list_backups() {
    echo -e "${BLUE}Available backups:${NC}"
    echo

    if [[ ! -d "${DOTFILES_STATE_DIR}/backups" ]]; then
        log_warning "No backups found"
        return 1
    fi

    for backup_path in "${DOTFILES_STATE_DIR}/backups"/*/; do
        backup=$(basename "$backup_path")
        [[ "$backup" == "*" ]] && continue
        if [[ -f "${DOTFILES_STATE_DIR}/backups/${backup}/metadata.json" ]]; then
            timestamp=$(grep '"timestamp"' "${DOTFILES_STATE_DIR}/backups/${backup}/metadata.json" | cut -d'"' -f4)
            echo -e "  ${GREEN}${backup}${NC} - ${timestamp}"
        else
            echo -e "  ${YELLOW}${backup}${NC} - (no metadata)"
        fi
    done
}

# Rollback to a specific backup
rollback() {
    local backup_id="${1:-}"

    if [[ -z "${backup_id}" ]]; then
        log_error "No backup ID provided"
        list_backups
        echo
        read -rp "Enter backup ID to rollback to: " backup_id
    fi

    local backup_path="${DOTFILES_STATE_DIR}/backups/${backup_id}"

    if [[ ! -d "${backup_path}" ]]; then
        log_error "Backup ${backup_id} not found!"
        return 1
    fi

    log_warning "Rolling back to ${backup_id}..."
    echo "This will:"
    echo "  1. Remove current symlinks"
    echo "  2. Restore files from backup"
    echo "  3. Recreate symlinks from manifest"
    echo
    read -p "Continue? [y/N] " -n 1 -r
    echo

    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        log_info "Rollback cancelled"
        return 0
    fi

    # Create rollback record
    echo "$(date +%s):${backup_id}" >> "${ROLLBACK_LOG}"

    # Remove current symlinks
    if [[ -f "${MANIFEST_FILE}" ]]; then
        while IFS=: read -r link target; do
            if [[ -L "${link}" ]]; then
                log_info "Removing symlink ${link}"
                rm "${link}"
            fi
        done < "${MANIFEST_FILE}"
    fi

    # Restore backed up files. Surface any cp failure — a silent failure
    # here looks identical to "rollback succeeded" but leaves the system
    # in an inconsistent half-rolled-back state. For directories, remove
    # the current target first so the restore is a *replace* rather than a
    # merge (cp -r merges, leaving stale files behind that weren't in the
    # backup); -f stops cp from prompting on read-only targets.
    #
    # Enable dotglob so the loop sees backed-up dotfiles (.zshrc, .vimrc,
    # …) — bash globs skip leading-dot entries by default, and missing
    # those would mean rollback restored almost nothing.
    local restore_failed=0
    # `shopt -p X Y` returns non-zero when any listed option is unset, which
    # would abort under `set -e`. Suppress the rc — we only need the printable
    # restore snippet, not the "are they currently set?" verdict.
    local prev_dotglob
    prev_dotglob=$(shopt -p dotglob nullglob || true)
    shopt -s dotglob nullglob
    for file in "${backup_path}"/*; do
        file="${file##*/}"
        if [[ "${file}" != "manifest" && "${file}" != "metadata.json" && "${file}" != "manifest.backup" ]]; then
            log_info "Restoring ${file}"
            # rm before cp so directories get *replaced*, not merged. If rm
            # fails (immutable bit, permission denied, …) cp would silently
            # merge into the existing tree and leave stale files behind —
            # treat that as a restore failure and skip the cp.
            if ! rm -rf "${HOME:?}/${file}"; then
                log_error "  Failed to clear ${file} before restore"
                restore_failed=$((restore_failed + 1))
                continue
            fi
            if ! cp -rf "${backup_path}/${file}" "${HOME}/"; then
                log_error "  Failed to restore ${file}"
                restore_failed=$((restore_failed + 1))
            fi
        fi
    done
    eval "$prev_dotglob"
    if (( restore_failed > 0 )); then
        log_warning "${restore_failed} file(s) failed to restore — system may be inconsistent."
    fi

    # Restore symlinks from manifest. If a path already exists (real file
    # OR broken symlink left over from a partial rollback), warn instead of
    # silently skipping. `[[ -e ]]` alone is false for dangling symlinks,
    # so add `-L` to catch those too — the conflict-detection contract is
    # "anything occupying that path", not "anything readable through it".
    if [[ -f "${backup_path}/manifest" ]]; then
        local symlink_conflicts=0
        while IFS=: read -r link target; do
            if [[ -e "${link}" || -L "${link}" ]]; then
                log_warning "Skipping symlink ${link} — path already exists (rollback may be incomplete)"
                symlink_conflicts=$((symlink_conflicts + 1))
            elif [[ -e "${target}" ]]; then
                log_info "Recreating symlink ${link}"
                ln -s "${target}" "${link}"
            fi
        done < "${backup_path}/manifest"
        if (( symlink_conflicts > 0 )); then
            log_warning "${symlink_conflicts} symlink(s) skipped due to existing files at the same path."
        fi
    fi

    # Restore the manifest
    if [[ -f "${backup_path}/manifest" ]]; then
        cp "${backup_path}/manifest" "${MANIFEST_FILE}"
    fi

    log_success "Rollback to ${backup_id} completed!"
}

# Main sync function
run_sync() {
    init_state
    backup_current_state
    parse_sync_args "$@"

    # Bootstrap yq (needed by packages/sync.sh to parse YAML)
    if [[ "$(uname)" == "Darwin" ]] && ! command -v yq &>/dev/null; then
      log_info "Bootstrapping yq..."
      brew install yq
    fi

    log_info "Syncing packages"
    bash "$dir/packages/sync.sh"

    upgrade_uv_tools

    log_info "Creating $olddir for backup of any existing dotfiles in ~"
    mkdir -p "$olddir"

    for file in *; do
        sync_entry "$file"
    done
    sync_hidden_dirs

    install_tpm
    install_prek_hooks

    create_manifest

    unset DOTFILES_DEV

    log_success "Sync completed successfully!"
    echo
    log_info "Backup saved at: ${BACKUP_DIR}"
    log_info "To rollback, run: $0 rollback ${BACKUP_DIR##*/}"
}

# Clean old backups, keeping the N most recent
clean_backups() {
    local keep="${1:-5}"
    local dry_run="${2:-false}"
    local backup_base="${DOTFILES_STATE_DIR}/backups"

    if [[ ! -d "$backup_base" ]]; then
        log_warning "No backups directory found"
        return 0
    fi

    # List backup dirs sorted oldest first
    local all_backups=()
    while IFS= read -r d; do
        [[ -d "$d" ]] && all_backups+=("$d")
    done < <(ls -dt "$backup_base"/*/ 2>/dev/null)

    local total=${#all_backups[@]}
    if [[ $total -le $keep ]]; then
        log_info "Only $total backup(s) found, keeping all (threshold: $keep)"
        return 0
    fi

    local to_delete=("${all_backups[@]:$keep}")
    local delete_count=${#to_delete[@]}

    if [[ "$dry_run" == "true" ]]; then
        echo -e "${BLUE}Dry run: would delete $delete_count backup(s), keeping $keep most recent${NC}"
        echo
        for b in "${to_delete[@]}"; do
            local size
            size=$(du -sh "$b" 2>/dev/null | cut -f1)
            echo -e "  ${RED}DELETE${NC} $(basename "$b")  ($size)"
        done
        echo
        echo -e "${GREEN}KEEP:${NC}"
        for b in "${all_backups[@]:0:$keep}"; do
            echo -e "  ${GREEN}KEEP${NC}   $(basename "$b")"
        done
    else
        log_info "Deleting $delete_count old backup(s), keeping $keep most recent..."
        for b in "${to_delete[@]}"; do
            local name
            name="${b##*/}"
            rm -rf "$b"
            log_info "Deleted $name"
        done
        log_success "Cleaned $delete_count backup(s). $keep remaining."
    fi
}

# Help message
show_help() {
    echo "Usage: $0 [OPTION]"
    echo
    echo "Options:"
    echo "  (no args)      Run normal sync with backup"
    echo "  dev            Set dev mode"
    echo "  q              Quick sync"
    echo "  refresh        Force re-check all packages (bypass cache)"
    echo "  rollback [ID]  Rollback to a specific backup"
    echo "  list-backups   List available backups"
    echo "  clean          Prune old backups (--keep=N, --dry-run)"
    echo "  help           Show this help message"
}

########## Main

case "${1:-sync}" in
    help|--help|-h)
        show_help
        ;;
    rollback)
        rollback "${2:-}"
        ;;
    list-backups)
        list_backups
        ;;
    clean)
        shift
        keep=5
        dry_run=false
        for arg in "$@"; do
            case "$arg" in
                --keep=*) keep="${arg#--keep=}" ;;
                --dry-run) dry_run=true ;;
            esac
        done
        clean_backups "$keep" "$dry_run"
        ;;
    *)
        run_sync "$@"
        ;;
esac
