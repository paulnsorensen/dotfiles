#!/bin/bash
# Symlink skhd config and ensure the brew service is running.

set -euo pipefail

if [[ "$(uname -s)" != "Darwin" ]]; then
    echo "skhd/.sync: skipping (not macOS)" >&2
    exit 0
fi

readonly SCRIPT_DIR="$(cd "${BASH_SOURCE%/*}" && pwd)"

if ! command -v skhd >/dev/null 2>&1; then
    echo "skhd/.sync: skhd not installed yet (run dots sync to install)" >&2
    exit 0
fi

ln -sfn "$SCRIPT_DIR/skhdrc" "$HOME/.skhdrc"

# skhd manages its own launchd service — it ships NO brew service definition
# (`brew services start skhd` aborts with "has not implemented #service"), so
# use its native `--start-service`, which installs the LaunchAgent on first run.
if pgrep -x skhd >/dev/null 2>&1; then
    echo "skhd/.sync: config linked, service already running"
else
    skhd --start-service >/dev/null 2>&1 || true
    sleep 1
    if pgrep -x skhd >/dev/null 2>&1; then
        echo "skhd/.sync: config linked, service started"
    else
        # Almost always missing Accessibility access — a manual, un-scriptable
        # System Settings grant. skhd aborts on launch until it is granted.
        echo "skhd/.sync: config linked, but skhd is not running." >&2
        echo "  Grant Accessibility access to skhd: System Settings →" >&2
        echo "  Privacy & Security → Accessibility, then: skhd --restart-service" >&2
    fi
fi
